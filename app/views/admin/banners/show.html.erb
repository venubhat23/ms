<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @banner.title %></h2>
    <p class="text-muted mb-0">Banner details and preview</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_banner_path(@banner), class: "btn btn-outline-warning" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Banner
    <% end %>
    <%= link_to toggle_status_admin_banner_path(@banner),
        method: :patch,
        class: "btn btn-outline-#{@banner.status? ? 'secondary' : 'success'}",
        data: {
          confirm: "Are you sure you want to #{@banner.status? ? 'deactivate' : 'activate'} this banner?",
          turbo_method: :patch
        } do %>
      <i class="bi bi-#{@banner.status? ? 'pause-circle' : 'play-circle'} me-1"></i>
      <%= @banner.status? ? 'Deactivate' : 'Activate' %>
    <% end %>
    <%= link_to admin_banners_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Banners
    <% end %>
  </div>
</div>

<!-- Banner Status Alert -->
<% if @banner.expired? %>
  <div class="alert alert-warning d-flex align-items-center mb-4">
    <i class="bi bi-clock-history me-2"></i>
    <div>
      <strong>Expired Banner:</strong> This banner expired on <%= @banner.display_end_date.strftime('%B %d, %Y') %> and is no longer displayed to users.
    </div>
  </div>
<% elsif @banner.upcoming? %>
  <div class="alert alert-info d-flex align-items-center mb-4">
    <i class="bi bi-calendar-event me-2"></i>
    <div>
      <strong>Upcoming Banner:</strong> This banner will start displaying on <%= @banner.display_start_date.strftime('%B %d, %Y') %>.
    </div>
  </div>
<% elsif @banner.current? && @banner.status? %>
  <div class="alert alert-success d-flex align-items-center mb-4">
    <i class="bi bi-check-circle me-2"></i>
    <div>
      <strong>Currently Active:</strong> This banner is currently being displayed to users.
    </div>
  </div>
<% elsif !@banner.status? %>
  <div class="alert alert-secondary d-flex align-items-center mb-4">
    <i class="bi bi-pause-circle me-2"></i>
    <div>
      <strong>Inactive Banner:</strong> This banner is currently deactivated and not displayed to users.
    </div>
  </div>
<% end %>

<div class="row">
  <!-- Banner Preview -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Banner Preview</h5>
      </div>
      <div class="card-body">
        <% if @banner.has_image? %>
          <div class="text-center mb-4">
            <%= image_tag @banner.main_image_url, class: "img-fluid rounded shadow-sm", style: "max-width: 100%; max-height: 400px;" %>
            <% info = @banner.image_display_info %>
            <div class="mt-2">
              <span class="badge <%= info[:class] %> bg-opacity-10 text-<%= info[:class].split('-').last %>">
                <i class="<%= info[:icon] %> me-1"></i><%= info[:type] %>
              </span>
            </div>

            <!-- Image Management Actions -->
            <div class="mt-3">
              <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="viewImage('<%= @banner.main_image_url %>', 'Banner Image')" title="View full image">
                  <i class="bi bi-eye me-1"></i>View Full
                </button>
                <button type="button" class="btn btn-outline-info btn-sm" onclick="copyImageUrl('<%= @banner.main_image_url %>')" title="Copy image URL">
                  <i class="bi bi-link-45deg me-1"></i>Copy URL
                </button>
                <% if @banner.r2_image_url.present? %>
                  <button type="button" class="btn btn-outline-success btn-sm" onclick="downloadImage('<%= @banner.r2_image_url %>', '<%= @banner.title %>')" title="Download image">
                    <i class="bi bi-download me-1"></i>Download
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="text-center py-5 bg-light rounded">
            <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
            <p class="text-muted mt-3 mb-0">No image uploaded</p>
          </div>
        <% end %>

        <% if @banner.description.present? %>
          <div class="mt-4">
            <h6 class="text-muted mb-2">Description</h6>
            <p class="mb-0"><%= simple_format(@banner.description) %></p>
          </div>
        <% end %>

        <% if @banner.redirect_link.present? %>
          <div class="mt-4">
            <h6 class="text-muted mb-2">Redirect Link</h6>
            <p class="mb-0">
              <%= link_to @banner.redirect_link, @banner.redirect_link,
                  target: "_blank",
                  class: "text-decoration-none",
                  title: "Open in new tab" %>
              <i class="bi bi-box-arrow-up-right ms-1"></i>
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Banner Details -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">Banner Details</h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <!-- Status -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Status</label>
            <div>
              <span class="badge bg-<%= @banner.status? ? 'success' : 'secondary' %> fs-6">
                <%= @banner.status? ? 'Active' : 'Inactive' %>
              </span>
            </div>
          </div>

          <!-- Display Location -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Display Location</label>
            <div>
              <span class="badge bg-primary fs-6"><%= @banner.display_location_humanized %></span>
            </div>
          </div>

          <!-- Display Order -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Display Order</label>
            <div>
              <span class="badge bg-info fs-6"><%= @banner.display_order %></span>
            </div>
          </div>

          <!-- Display Period -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Display Period</label>
            <div>
              <small class="d-block">
                <strong>Start:</strong> <%= @banner.display_start_date.strftime('%B %d, %Y') %>
              </small>
              <small class="d-block">
                <strong>End:</strong> <%= @banner.display_end_date.strftime('%B %d, %Y') %>
              </small>
              <small class="d-block mt-2">
                <% if @banner.current? %>
                  <span class="text-success"><i class="bi bi-circle-fill me-1"></i>Currently Active</span>
                <% elsif @banner.expired? %>
                  <span class="text-danger"><i class="bi bi-circle-fill me-1"></i>Expired</span>
                <% else %>
                  <span class="text-warning"><i class="bi bi-circle-fill me-1"></i>Upcoming</span>
                <% end %>
              </small>
            </div>
          </div>

          <!-- Created At -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Created</label>
            <div>
              <small><%= @banner.created_at.strftime('%B %d, %Y at %I:%M %p') %></small>
            </div>
          </div>

          <!-- Updated At -->
          <div class="col-12">
            <label class="form-label text-muted mb-1">Last Modified</label>
            <div>
              <small><%= @banner.updated_at.strftime('%B %d, %Y at %I:%M %p') %></small>
            </div>
          </div>

          <!-- Image Details -->
          <% if @banner.has_image? %>
            <div class="col-12">
              <label class="form-label text-muted mb-1">Image Details</label>
              <div>
                <% info = @banner.image_display_info %>
                <small class="d-block mb-1">
                  <strong>Storage:</strong>
                  <span class="badge <%= info[:class] %> bg-opacity-10 text-<%= info[:class].split('-').last %>">
                    <i class="<%= info[:icon] %> me-1"></i><%= info[:type] %>
                  </span>
                </small>

                <% if @banner.r2_image_url.present? %>
                  <small class="d-block text-break mb-1">
                    <strong>Public URL:</strong><br>
                    <span class="text-primary"><%= @banner.r2_image_url %></span>
                  </small>
                  <small class="d-block">
                    <strong>Benefits:</strong> Global CDN, Fast delivery, Cost-effective
                  </small>
                <% elsif @banner.image_url.present? %>
                  <small class="d-block mb-1">
                    <strong>Public ID:</strong> <%= @banner.image_url %>
                  </small>
                  <small class="d-block text-break mb-1">
                    <strong>CDN URL:</strong><br>
                    <span class="text-success"><%= @banner.cloudinary_image_url %></span>
                  </small>
                  <small class="d-block">
                    <strong>Optimizations:</strong> Auto quality, format optimization
                  </small>
                <% elsif @banner.banner_image.attached? %>
                  <small class="d-block mb-1">
                    <strong>Filename:</strong> <%= @banner.banner_image.filename %>
                  </small>
                  <small class="d-block mb-1">
                    <strong>Size:</strong> <%= number_to_human_size(@banner.banner_image.byte_size) %>
                  </small>
                  <small class="d-block">
                    <strong>Type:</strong> <%= @banner.banner_image.content_type %>
                  </small>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm mt-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">Quick Actions</h6>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to edit_admin_banner_path(@banner), class: "btn btn-outline-primary btn-sm" do %>
            <i class="bi bi-pencil me-2"></i>Edit Banner
          <% end %>

          <% if @banner.has_image? %>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="viewImage('<%= @banner.main_image_url %>', 'Banner Image')">
              <i class="bi bi-eye me-2"></i>View Full Image
            </button>

            <button type="button" class="btn btn-outline-info btn-sm" onclick="copyImageUrl('<%= @banner.main_image_url %>')">
              <i class="bi bi-clipboard me-2"></i>Copy Image URL
            </button>

            <% if @banner.r2_image_url.present? %>
              <button type="button" class="btn btn-outline-success btn-sm" onclick="downloadImage('<%= @banner.r2_image_url %>', '<%= @banner.title %>')">
                <i class="bi bi-download me-2"></i>Download from R2
              </button>
            <% elsif @banner.image_url.present? %>
              <%= link_to @banner.cloudinary_image_url, target: "_blank", class: "btn btn-outline-success btn-sm" do %>
                <i class="bi bi-box-arrow-up-right me-2"></i>Open Cloudinary
              <% end %>
            <% elsif @banner.banner_image.attached? %>
              <%= link_to rails_blob_path(@banner.banner_image, disposition: "attachment"), class: "btn btn-outline-success btn-sm" do %>
                <i class="bi bi-download me-2"></i>Download Local
              <% end %>
            <% end %>
          <% end %>

          <%= link_to toggle_status_admin_banner_path(@banner),
              method: :patch,
              class: "btn btn-outline-#{@banner.status? ? 'warning' : 'success'} btn-sm",
              data: {
                confirm: "Are you sure you want to #{@banner.status? ? 'deactivate' : 'activate'} this banner?",
                turbo_method: :patch
              } do %>
            <i class="bi bi-#{@banner.status? ? 'pause-circle' : 'play-circle'} me-2"></i>
            <%= @banner.status? ? 'Deactivate' : 'Activate' %>
          <% end %>

          <%= button_to admin_banner_path(@banner),
              method: :delete,
              class: "btn btn-outline-danger btn-sm",
              data: {
                confirm: "Are you sure you want to delete this banner? This action cannot be undone."
              } do %>
            <i class="bi bi-trash me-2"></i>Delete Banner
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Image Management JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // View image in modal
  window.viewImage = function(imageUrl, title) {
    if (!imageUrl) {
      alert('No image URL available');
      return;
    }

    const modal = document.createElement('div');
    modal.className = 'modal fade';
    modal.innerHTML = `
      <div class="modal-dialog modal-xl">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">${title}</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body text-center">
            <img src="${imageUrl}" alt="${title}" class="img-fluid rounded shadow-sm" style="max-width: 100%; max-height: 80vh;">
            <div class="mt-3">
              <small class="text-muted d-block">Click and drag to pan • Scroll to zoom</small>
              <small class="text-muted">${imageUrl}</small>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <a href="${imageUrl}" target="_blank" class="btn btn-primary">Open in New Tab</a>
            <button type="button" class="btn btn-success" onclick="copyImageUrl('${imageUrl}')">
              <i class="bi bi-clipboard me-1"></i>Copy URL
            </button>
          </div>
        </div>
      </div>
    `;

    document.body.appendChild(modal);
    const bootstrapModal = new bootstrap.Modal(modal);
    bootstrapModal.show();

    modal.addEventListener('hidden.bs.modal', () => {
      document.body.removeChild(modal);
    });
  };

  // Copy image URL to clipboard
  window.copyImageUrl = function(imageUrl) {
    if (!imageUrl) {
      alert('No image URL available to copy');
      return;
    }

    navigator.clipboard.writeText(imageUrl).then(() => {
      // Show success toast
      const toast = document.createElement('div');
      toast.className = 'position-fixed top-0 start-50 translate-middle-x mt-3';
      toast.style.zIndex = '9999';
      toast.innerHTML = `
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-check-circle me-2"></i>
          <strong>Success!</strong> Image URL copied to clipboard.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      `;
      document.body.appendChild(toast);

      setTimeout(() => {
        if (document.body.contains(toast)) {
          document.body.removeChild(toast);
        }
      }, 3000);
    }).catch(err => {
      console.error('Failed to copy: ', err);
      alert('Failed to copy URL to clipboard. Please copy manually: ' + imageUrl);
    });
  };

  // Download image from R2
  window.downloadImage = function(imageUrl, filename) {
    if (!imageUrl) {
      alert('No image URL available for download');
      return;
    }

    // Create a temporary anchor element to trigger download
    const link = document.createElement('a');
    link.href = imageUrl;
    link.download = filename ? `${filename}.jpg` : 'banner-image.jpg';
    link.target = '_blank';

    // Append to body, click, then remove
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    // Show success feedback
    const toast = document.createElement('div');
    toast.className = 'position-fixed top-0 start-50 translate-middle-x mt-3';
    toast.style.zIndex = '9999';
    toast.innerHTML = `
      <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-download me-2"></i>
        <strong>Download started!</strong> Check your downloads folder.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    `;
    document.body.appendChild(toast);

    setTimeout(() => {
      if (document.body.contains(toast)) {
        document.body.removeChild(toast);
      }
    }, 3000);
  };
});
</script>