<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Edit Invoice</h2>
    <p class="text-muted mb-0">Update invoice details and line items for <%= @invoice.customer&.display_name || @invoice.customer_display_name %></p>
  </div>
  <div>
    <%= link_to admin_invoices_path, class: "btn btn-outline-secondary me-2" do %>
      <i class="bi bi-arrow-left me-1"></i>Back to Invoices
    <% end %>
    <%= link_to admin_invoice_path(@invoice), class: "btn btn-outline-primary" do %>
      <i class="bi bi-eye me-1"></i>View Invoice
    <% end %>
  </div>
</div>

<%= form_with model: [:admin, @invoice], local: true, class: "invoice-edit-form" do |f| %>
  <% if @invoice.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <h6 class="alert-heading">Please correct the following errors:</h6>
      <ul class="mb-0">
        <% @invoice.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <!-- Invoice Details -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
          <h6 class="mb-0 text-dark">Invoice Details</h6>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :invoice_date, class: "form-label" %>
              <%= f.date_field :invoice_date, class: "form-control" %>
            </div>

            <div class="col-md-6">
              <%= f.label :due_date, class: "form-label" %>
              <%= f.date_field :due_date, class: "form-control" %>
            </div>

            <div class="col-md-6">
              <%= f.label :status, class: "form-label" %>
              <%= f.select :status, options_for_select([
                    ['Draft', 'draft'],
                    ['Sent', 'sent'],
                    ['Paid', 'paid'],
                    ['Cancelled', 'cancelled']
                  ], @invoice.status), {}, { class: "form-select" } %>
            </div>

            <div class="col-md-6">
              <%= f.label :payment_status, class: "form-label" %>
              <%= f.select :payment_status, options_for_select([
                    ['Unpaid', 'unpaid'],
                    ['Partially Paid', 'partially_paid'],
                    ['Fully Paid', 'fully_paid']
                  ], @invoice.payment_status), {}, { class: "form-select" } %>
            </div>

            <div class="col-12">
              <%= f.label :notes, class: "form-label" %>
              <%= f.text_area :notes, rows: 3, class: "form-control", placeholder: "Add any notes or comments..." %>
            </div>
          </div>
        </div>
      </div>

      <!-- Invoice Line Items -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
          <h6 class="mb-0 text-dark">Invoice Line Items</h6>
          <button type="button" class="btn btn-primary btn-sm" onclick="addNewLineItem()">
            <i class="bi bi-plus-lg me-1"></i>Add Product
          </button>
        </div>
        <div class="card-body">
          <div id="line-items-container">
            <% @invoice_items.each_with_index do |item, index| %>
              <div class="line-item-row" data-index="<%= index %>">
                <div class="row g-3 align-items-end">
                  <div class="col-md-5">
                    <label class="form-label">Product</label>
                    <select name="invoice[invoice_items_attributes][<%= index %>][product_id]" class="form-select product-select" data-current-product="<%= item.product_id %>" onchange="updateProductPrice(this)">
                      <option value="">Select Product...</option>
                      <% Product.active.includes(:category).order(:name).each do |product| %>
                        <option value="<%= product.id %>"
                                data-price="<%= product.selling_price %>"
                                data-description="<%= product.name %>"
                                <%= 'selected' if item.product_id == product.id %>>
                          <%= product.name %> - ₹<%= product.selling_price %>/<%= product.unit_type %>
                        </option>
                      <% end %>
                    </select>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Quantity</label>
                    <input type="number"
                           name="invoice[invoice_items_attributes][<%= index %>][quantity]"
                           value="<%= item.quantity %>"
                           min="1"
                           step="1"
                           class="form-control quantity-input"
                           onchange="calculateLineTotal(this)"
                           required>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Unit Price</label>
                    <div class="input-group">
                      <span class="input-group-text">₹</span>
                      <input type="number"
                             name="invoice[invoice_items_attributes][<%= index %>][unit_price]"
                             value="<%= item.unit_price %>"
                             step="0.01"
                             min="0"
                             class="form-control unit-price-input"
                             onchange="calculateLineTotal(this)"
                             required>
                    </div>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Total</label>
                    <div class="input-group">
                      <span class="input-group-text">₹</span>
                      <input type="number"
                             name="invoice[invoice_items_attributes][<%= index %>][total_amount]"
                             value="<%= item.total_amount %>"
                             step="0.01"
                             class="form-control line-total"
                             readonly>
                    </div>
                  </div>
                  <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeLineItem(this)" title="Remove Item">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </div>
                <div class="row mt-2">
                  <div class="col-12">
                    <input type="text"
                           name="invoice[invoice_items_attributes][<%= index %>][description]"
                           value="<%= item.description %>"
                           class="form-control"
                           placeholder="Item description (optional)">
                  </div>
                </div>
                <input type="hidden" name="invoice[invoice_items_attributes][<%= index %>][id]" value="<%= item.id %>">
              </div>
              <% unless index == @invoice_items.length - 1 %>
                <hr class="my-3">
              <% end %>
            <% end %>

            <!-- Template for new items (hidden) -->
            <div id="line-item-template" style="display: none;">
              <div class="line-item-row" data-index="">
                <div class="row g-3 align-items-end">
                  <div class="col-md-5">
                    <label class="form-label">Product</label>
                    <select name="" class="form-select product-select" onchange="updateProductPrice(this)">
                      <option value="">Select Product...</option>
                      <% Product.active.includes(:category).order(:name).each do |product| %>
                        <option value="<%= product.id %>"
                                data-price="<%= product.selling_price %>"
                                data-description="<%= product.name %>">
                          <%= product.name %> - ₹<%= product.selling_price %>/<%= product.unit_type %>
                        </option>
                      <% end %>
                    </select>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Quantity</label>
                    <input type="number"
                           name=""
                           value="1"
                           min="1"
                           step="1"
                           class="form-control quantity-input"
                           onchange="calculateLineTotal(this)"
                           required>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Unit Price</label>
                    <div class="input-group">
                      <span class="input-group-text">₹</span>
                      <input type="number"
                             name=""
                             value="0"
                             step="0.01"
                             min="0"
                             class="form-control unit-price-input"
                             onchange="calculateLineTotal(this)"
                             required>
                    </div>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Total</label>
                    <div class="input-group">
                      <span class="input-group-text">₹</span>
                      <input type="number"
                             name=""
                             value="0"
                             step="0.01"
                             class="form-control line-total"
                             readonly>
                    </div>
                  </div>
                  <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeLineItem(this)" title="Remove Item">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </div>
                <div class="row mt-2">
                  <div class="col-12">
                    <input type="text"
                           name=""
                           class="form-control"
                           placeholder="Item description (optional)">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <% if @invoice_items.empty? %>
            <div id="no-items-message" class="text-center py-4 text-muted">
              <i class="bi bi-plus-circle display-4 d-block mb-2"></i>
              <p>No line items yet. Click "Add Product" to get started.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Invoice Summary -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm sticky-top" style="top: 2rem;">
        <div class="card-header bg-white border-0 py-3">
          <h6 class="mb-0 text-dark">Invoice Summary</h6>
        </div>
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">Invoice Number</span>
            <span class="fw-medium"><%= @invoice.invoice_number %></span>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">Customer</span>
            <span class="fw-medium"><%= @invoice.customer&.display_name || @invoice.customer_display_name %></span>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">Current Status</span>
            <% case @invoice.payment_status %>
            <% when 'fully_paid' %>
              <span class="badge bg-success">Paid</span>
            <% when 'partially_paid' %>
              <span class="badge bg-warning">Partial</span>
            <% else %>
              <span class="badge bg-secondary">Unpaid</span>
            <% end %>
          </div>

          <hr class="my-3">

          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted">Subtotal</span>
            <span class="fw-medium" id="subtotal-display">₹<%= number_with_delimiter(@invoice.total_amount.to_i) %></span>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">Tax</span>
            <span class="fw-medium">₹0.00</span>
          </div>

          <hr class="my-3">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-bold text-dark">Total Amount</span>
            <span class="fw-bold text-primary fs-5" id="total-display">₹<%= number_with_delimiter(@invoice.total_amount.to_i) %></span>
          </div>

          <!-- Hidden field for total amount -->
          <input type="hidden" name="invoice[total_amount]" id="total_amount_field" value="<%= @invoice.total_amount %>">

          <hr class="my-3">

          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Created</span>
            <span class="small"><%= @invoice.created_at.strftime("%d %b %Y") %></span>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted small">Last Updated</span>
            <span class="small"><%= @invoice.updated_at.strftime("%d %b %Y") %></span>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="mt-4">
        <div class="d-grid gap-2">
          <%= f.submit "Update Invoice", class: "btn btn-primary btn-lg" %>
          <%= link_to "Cancel", admin_invoice_path(@invoice), class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
let lineItemIndex = <%= @invoice_items.length %>;

// Add new line item
function addNewLineItem() {
  const container = document.getElementById('line-items-container');
  const template = document.getElementById('line-item-template');
  const newItem = template.cloneNode(true);

  // Remove template styling and ID
  newItem.style.display = 'block';
  newItem.removeAttribute('id');
  newItem.setAttribute('data-index', lineItemIndex);

  // Update input names with new index
  const inputs = newItem.querySelectorAll('input, select');
  inputs.forEach(input => {
    const nameAttr = input.getAttribute('name');
    if (nameAttr) {
      const newName = nameAttr.replace(/\[\d*\]/, `[${lineItemIndex}]`);
      input.setAttribute('name', `invoice[invoice_items_attributes][${lineItemIndex}]${getFieldName(input)}`);
    }
  });

  // Add separator if not first item
  if (container.children.length > 0) {
    const separator = document.createElement('hr');
    separator.className = 'my-3';
    container.appendChild(separator);
  }

  container.appendChild(newItem);

  // Hide no items message
  const noItemsMsg = document.getElementById('no-items-message');
  if (noItemsMsg) {
    noItemsMsg.style.display = 'none';
  }

  lineItemIndex++;

  // Scroll to new item
  newItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// Get field name from input
function getFieldName(input) {
  const classList = Array.from(input.classList);

  if (classList.includes('product-select')) return '[product_id]';
  if (classList.includes('quantity-input')) return '[quantity]';
  if (classList.includes('unit-price-input')) return '[unit_price]';
  if (classList.includes('line-total')) return '[total_amount]';
  if (input.placeholder && input.placeholder.includes('description')) return '[description]';

  return '';
}

// Remove line item
function removeLineItem(button) {
  const lineItem = button.closest('.line-item-row');
  const prevSeparator = lineItem.previousElementSibling;
  const nextSeparator = lineItem.nextElementSibling;

  // Remove separators
  if (prevSeparator && prevSeparator.tagName === 'HR') {
    prevSeparator.remove();
  } else if (nextSeparator && nextSeparator.tagName === 'HR') {
    nextSeparator.remove();
  }

  // Add hidden input for deletion if this is an existing item
  const itemId = lineItem.querySelector('input[name*="[id]"]');
  if (itemId && itemId.value) {
    const deleteField = document.createElement('input');
    deleteField.type = 'hidden';
    deleteField.name = itemId.name.replace('[id]', '[_destroy]');
    deleteField.value = '1';
    lineItem.appendChild(deleteField);
    lineItem.style.display = 'none';
  } else {
    lineItem.remove();
  }

  // Show no items message if container is empty
  const container = document.getElementById('line-items-container');
  const visibleItems = container.querySelectorAll('.line-item-row[style*="display: none"], .line-item-row:not([style])').length;

  if (visibleItems === 0) {
    const noItemsMsg = document.getElementById('no-items-message');
    if (noItemsMsg) {
      noItemsMsg.style.display = 'block';
    }
  }

  updateInvoiceTotal();
}

// Update product price when product is selected
function updateProductPrice(selectElement) {
  const selectedOption = selectElement.options[selectElement.selectedIndex];
  const lineItem = selectElement.closest('.line-item-row');
  const unitPriceInput = lineItem.querySelector('.unit-price-input');
  const descriptionInput = lineItem.querySelector('input[placeholder*="description"]');

  if (selectedOption.value) {
    const price = selectedOption.getAttribute('data-price');
    const description = selectedOption.getAttribute('data-description');

    unitPriceInput.value = price || 0;
    if (descriptionInput && description) {
      descriptionInput.value = description;
    }

    calculateLineTotal(unitPriceInput);
  } else {
    unitPriceInput.value = 0;
    calculateLineTotal(unitPriceInput);
  }
}

// Calculate line total
function calculateLineTotal(changedElement) {
  const lineItem = changedElement.closest('.line-item-row');
  const quantity = parseFloat(lineItem.querySelector('.quantity-input').value) || 0;
  const unitPrice = parseFloat(lineItem.querySelector('.unit-price-input').value) || 0;
  const totalInput = lineItem.querySelector('.line-total');

  const total = quantity * unitPrice;
  totalInput.value = total.toFixed(2);

  updateInvoiceTotal();
}

// Update invoice total
function updateInvoiceTotal() {
  let subtotal = 0;

  // Sum all line totals
  document.querySelectorAll('.line-item-row:not([style*="display: none"]) .line-total').forEach(input => {
    const value = parseFloat(input.value) || 0;
    subtotal += value;
  });

  // Update display
  const subtotalDisplay = document.getElementById('subtotal-display');
  const totalDisplay = document.getElementById('total-display');
  const totalField = document.getElementById('total_amount_field');

  if (subtotalDisplay) {
    subtotalDisplay.textContent = `₹${subtotal.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  }

  if (totalDisplay) {
    totalDisplay.textContent = `₹${subtotal.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  }

  if (totalField) {
    totalField.value = subtotal.toFixed(2);
  }
}

// Initialize totals on page load
document.addEventListener('DOMContentLoaded', function() {
  // Set current product selections
  document.querySelectorAll('.product-select[data-current-product]').forEach(select => {
    const currentProduct = select.getAttribute('data-current-product');
    if (currentProduct) {
      select.value = currentProduct;
    }
  });

  updateInvoiceTotal();

  // Add change listeners to existing items
  document.querySelectorAll('.quantity-input, .unit-price-input').forEach(input => {
    input.addEventListener('change', function() {
      calculateLineTotal(this);
    });
  });
});
</script>

<style>
.line-item-row {
  position: relative;
  padding: 1rem;
  border: 1px solid #e9ecef;
  border-radius: 0.5rem;
  background-color: #f8f9fa;
  margin-bottom: 1rem;
  transition: all 0.2s ease;
}

.line-item-row:hover {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.125rem rgba(13, 110, 253, 0.1);
}

.line-item-row .btn-outline-danger {
  border-color: #dc3545;
}

.line-item-row .btn-outline-danger:hover {
  background-color: #dc3545;
  color: white;
}

.sticky-top {
  z-index: 1020;
}

.invoice-edit-form .form-control:focus,
.invoice-edit-form .form-select:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
}

#no-items-message {
  border: 2px dashed #dee2e6;
  border-radius: 0.5rem;
  color: #6c757d;
}

#no-items-message i {
  color: #adb5bd;
}

.card {
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-1px);
  box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
}
</style>