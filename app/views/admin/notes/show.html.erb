<% content_for :title, "Payment Note Details" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center">
          <%= link_to admin_notes_path, class: "btn btn-outline-secondary me-3" do %>
            <i class="bi bi-arrow-left"></i>
          <% end %>
          <div class="d-flex align-items-center">
            <div class="icon-bg gradient-info me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; border-radius: 10px;">
              <i class="bi bi-eye text-white fs-5"></i>
            </div>
            <div>
              <h4 class="mb-1" style="color: #2c3e50; font-weight: 600;">Payment Note Details</h4>
              <p class="text-muted mb-0">View payment record information</p>
            </div>
          </div>
        </div>
        <div class="d-flex gap-2">
          <%= link_to edit_admin_note_path(@note), class: "btn btn-warning d-flex align-items-center gap-2" do %>
            <i class="bi bi-pencil"></i>
            Edit
          <% end %>
          <%= link_to admin_note_path(@note), method: :delete,
              class: "btn btn-danger d-flex align-items-center gap-2",
              confirm: "Are you sure you want to delete this note?" do %>
            <i class="bi bi-trash"></i>
            Delete
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Note Details Card -->
  <div class="card border-0 shadow-sm" style="border-radius: 12px;">
    <div class="card-body p-4">
      <div class="row">
        <!-- Left Column -->
        <div class="col-md-6">
          <!-- Title -->
          <div class="detail-group mb-4">
            <label class="detail-label">Payment Title</label>
            <div class="detail-value">
              <h5 class="mb-0 text-dark fw-semibold"><%= @note.title %></h5>
            </div>
          </div>

          <!-- Paid To -->
          <div class="detail-group mb-4">
            <label class="detail-label">Paid To</label>
            <div class="detail-value">
              <p class="mb-0 fs-5 text-dark"><%= @note.paid_to %></p>
            </div>
          </div>

          <!-- Amount -->
          <div class="detail-group mb-4">
            <label class="detail-label">Amount</label>
            <div class="detail-value">
              <h3 class="mb-0 text-success fw-bold">
                <i class="bi bi-currency-rupee"></i><%= number_with_delimiter(@note.amount.to_f) %>
              </h3>
            </div>
          </div>

          <!-- Payment Method -->
          <div class="detail-group mb-4">
            <label class="detail-label">Payment Method</label>
            <div class="detail-value">
              <div class="d-flex align-items-center gap-3">
                <div class="icon-circle">
                  <i class="<%= @note.payment_method_icon %> text-primary"></i>
                </div>
                <span class="fs-5 text-dark"><%= @note.payment_method.gsub('_', ' ') %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column -->
        <div class="col-md-6">
          <!-- Status -->
          <div class="detail-group mb-4">
            <label class="detail-label">Status</label>
            <div class="detail-value">
              <span class="badge <%= @note.status_badge_class %> px-4 py-3 fs-6">
                <%= @note.status.capitalize %>
              </span>
            </div>
          </div>

          <!-- Payment Date -->
          <div class="detail-group mb-4">
            <label class="detail-label">Payment Date</label>
            <div class="detail-value">
              <p class="mb-0 fs-5 text-dark">
                <i class="bi bi-calendar3 text-muted me-2"></i>
                <%= @note.formatted_date %>
              </p>
            </div>
          </div>

          <!-- Reference Number -->
          <div class="detail-group mb-4">
            <label class="detail-label">Reference Number</label>
            <div class="detail-value">
              <% if @note.reference_number.present? %>
                <code class="fs-6 px-3 py-2 bg-light border rounded"><%= @note.reference_number %></code>
              <% else %>
                <span class="text-muted fs-6">Not provided</span>
              <% end %>
            </div>
          </div>

          <!-- Created By -->
          <div class="detail-group mb-4">
            <label class="detail-label">Created By</label>
            <div class="detail-value">
              <div class="d-flex align-items-center gap-2">
                <div class="user-avatar">
                  <i class="bi bi-person-circle text-muted fs-4"></i>
                </div>
                <div>
                  <p class="mb-0 fw-semibold"><%= @note.created_by_user.first_name %> <%= @note.created_by_user.last_name %></p>
                  <small class="text-muted"><%= @note.created_at.strftime("%d %b %Y at %I:%M %p") %></small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Description Section (Full Width) -->
      <% if @note.description.present? %>
        <div class="row mt-4">
          <div class="col-12">
            <hr class="my-4">
            <div class="detail-group">
              <label class="detail-label">Description</label>
              <div class="detail-value">
                <div class="description-box">
                  <p class="mb-0 text-dark lh-lg"><%= simple_format(@note.description) %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Timestamps -->
      <div class="row mt-4">
        <div class="col-12">
          <hr class="my-4">
          <div class="row">
            <div class="col-md-6">
              <div class="detail-group-small">
                <label class="detail-label-small">Created</label>
                <p class="mb-0 text-muted small">
                  <i class="bi bi-calendar-plus me-1"></i>
                  <%= @note.created_at.strftime("%d %b %Y at %I:%M %p") %>
                </p>
              </div>
            </div>
            <div class="col-md-6">
              <div class="detail-group-small">
                <label class="detail-label-small">Last Updated</label>
                <p class="mb-0 text-muted small">
                  <i class="bi bi-calendar-check me-1"></i>
                  <%= @note.updated_at.strftime("%d %b %Y at %I:%M %p") %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="row mt-4">
    <div class="col-12">
      <div class="d-flex justify-content-between">
        <div>
          <%= link_to admin_notes_path, class: "btn btn-outline-secondary btn-lg px-4" do %>
            <i class="bi bi-arrow-left me-2"></i>Back to Notes
          <% end %>
        </div>
        <div class="d-flex gap-2">
          <%= link_to edit_admin_note_path(@note), class: "btn btn-warning btn-lg px-4" do %>
            <i class="bi bi-pencil me-2"></i>Edit Note
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.icon-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.gradient-info {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.card {
  border-radius: 12px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.detail-group {
  margin-bottom: 1.5rem;
}

.detail-group-small {
  margin-bottom: 1rem;
}

.detail-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.025em;
  margin-bottom: 0.5rem;
}

.detail-label-small {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.025em;
  margin-bottom: 0.25rem;
}

.detail-value {
  padding-left: 0;
}

.icon-circle {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
}

.description-box {
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 1.5rem;
}

.user-avatar {
  font-size: 1.5rem;
}

.badge {
  font-size: 0.875rem;
  font-weight: 500;
  border-radius: 8px;
  padding: 8px 16px;
}

.btn-lg {
  padding: 12px 24px;
  font-size: 1.1rem;
  border-radius: 8px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 8px rgba(0,0,0,0.15);
}

hr {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
}

code {
  background-color: #f1f5f9;
  color: #334155;
  font-size: 0.9rem;
  padding: 4px 8px;
  border-radius: 4px;
  border: 1px solid #e2e8f0;
}
</style>