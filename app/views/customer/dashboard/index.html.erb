                Cart empty
              <% end %>
            </div>
          </div>
          <div class="kpi-icon cart">
            <i class="bi bi-cart3"></i>
          </div>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-content">
          <div class="kpi-info">
            <div class="kpi-label">Active Subscriptions</div>
            <div class="kpi-value"><%= @active_subscriptions_count || 0 %></div>
            <div class="kpi-change <%= @active_subscriptions_count > 0 ? 'positive' : 'neutral' %>">
              <% if @active_subscriptions_count > 0 %>
                <i class="bi bi-arrow-up"></i>
                Active delivery
              <% else %>
