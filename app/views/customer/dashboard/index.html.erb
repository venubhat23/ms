<% content_for :title, 'Dashboard - Marali Santhe' %>
<% content_for :layout_class, 'customer-main-content' %>

<!-- Banner Configuration - Load First -->
<script type="text/javascript">
console.log('🎯 EARLY BANNER CONFIG LOADING...');
window.BANNER_CONFIG = {
  totalSlides: <%= (@dashboard_banners || []).size.to_i %>,
  hasBanners: <%= (@dashboard_banners&.any? || false).to_s %>,
  timestamp: '<%= Time.current.strftime('%H:%M:%S.%L') %>'
};
console.log('🎯 EARLY BANNER_CONFIG SET:', window.BANNER_CONFIG);
console.log('🎯 Dashboard banners from server:', <%= @dashboard_banners.present? %>);
console.log('🎯 Dashboard banners count:', <%= (@dashboard_banners || []).size.to_i %>);
</script>

<!-- IMMEDIATE Banner Modal Test Script -->
<script>
try {
  console.log('🎯 IMMEDIATE Banner Test Script Loading...');

  function testShowBanner() {
    console.log('🎯 testShowBanner called');
    console.log('🎯 DOM elements with id containing "banner":', document.querySelectorAll('[id*="banner"]'));
    var modal = document.getElementById('bannerModal');
    console.log('🎯 Modal found:', !!modal);
    if (!modal) {
      console.log('🎯 All modal elements:', document.querySelectorAll('.modal'));
      console.log('🎯 All banner-related elements:', document.querySelectorAll('[class*="banner"]'));
    }

    // Modal should already exist in DOM from server-side rendering (no dynamic creation needed)
    if (!modal) {
      console.log('🎯 Modal not found in DOM - skipping banner display');
      return;
    }

    if (modal && window.BANNER_CONFIG && window.BANNER_CONFIG.totalSlides > 0) {
      console.log('🎯 SHOWING BANNER NOW!');

      // Enhanced fade-in animation
      modal.style.display = 'block';
      document.body.classList.add('modal-open');

      // Trigger fade-in animation
      setTimeout(function() {
        modal.classList.add('show');
      }, 10); // Small delay to ensure display: block is applied first

      // Debug image loading
      var bannerImages = modal.querySelectorAll('.banner-main-image');
      console.log('🎯 Found', bannerImages.length, 'banner images');
      bannerImages.forEach(function(img, index) {
        console.log('🎯 Image', index + 1, 'src:', img.src);
        img.onload = function() {
          console.log('🎯 Image', index + 1, 'loaded successfully');
        };
        img.onerror = function() {
          console.log('🎯 Image', index + 1, 'failed to load');
        };
      });

      // Add escape key listener
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          window.closeBannerModal();
        }
      });

      // Auto-cycle through banners or auto-close after viewing all
      if (window.BANNER_CONFIG.totalSlides > 1) {
        console.log('🎯 Starting auto-cycle for multiple banners');
        window.startBannerAutoCycle();
      } else {
        // Auto-close single banner after 15 seconds
        setTimeout(function() {
          console.log('🎯 Auto-closing single banner after 30 seconds');
          window.closeBannerModal();
        }, 30000); // 30 seconds to allow more time to see the banner
      }

    } else {
      console.log('🎯 Cannot show banner - modal:', !!modal, 'config:', window.BANNER_CONFIG);
    }
  }

  // Close function with smooth fade-out
  window.closeBannerModal = function() {
    console.log('🎯 Closing banner modal...');

    // Stop auto-cycle functionality
    window.stopBannerAutoCycle();

    var modal = document.getElementById('bannerModal');
    if (modal) {
      // Start fade-out animation
      modal.classList.remove('show');
      document.body.classList.remove('modal-open');

      // Wait for fade-out animation to complete before hiding
      setTimeout(function() {
        modal.style.display = 'none';
      }, 300); // Match the CSS transition duration

      console.log('🎯 Modal closed, staying on dashboard');

      // Just stay on dashboard - no redirect needed
    }
  };

  // Show banner immediately when page loads
  document.addEventListener('DOMContentLoaded', testShowBanner);
  setTimeout(testShowBanner, 100);  // Very quick delay to ensure DOM is ready
  setTimeout(testShowBanner, 500);  // Backup attempt

  // Enhanced banner navigation functions
  let currentSlide = 0;
  let bannerCycleInterval = null;
  let bannerAutoCloseTimeout = null;
  const totalSlides = window.BANNER_CONFIG ? window.BANNER_CONFIG.totalSlides : 0;

  window.goToSlide = function(slideIndex) {
    const slides = document.querySelectorAll('.banner-slide');
    const dots = document.querySelectorAll('.simple-progress .dot');

    if (slides.length > 0 && slideIndex >= 0 && slideIndex < slides.length) {
      // Hide current slide
      slides[currentSlide].classList.remove('active');
      if (dots.length > 0) dots[currentSlide].classList.remove('active');

      // Show new slide
      currentSlide = slideIndex;
      slides[currentSlide].classList.add('active');
      if (dots.length > 0) dots[currentSlide].classList.add('active');

      console.log(`🎯 Showing banner slide ${currentSlide + 1} of ${totalSlides}`);
    }
  };

  window.nextSlide = function() {
    const nextIndex = (currentSlide + 1) % totalSlides;
    window.goToSlide(nextIndex);
  };

  window.previousSlide = function() {
    const prevIndex = (currentSlide - 1 + totalSlides) % totalSlides;
    window.goToSlide(prevIndex);
  };

  // Auto-cycle functionality for multiple banners
  window.startBannerAutoCycle = function() {
    let cycleCount = 0;

    bannerCycleInterval = setInterval(() => {
      const modal = document.getElementById('bannerModal');
      if (modal && modal.style.display === 'block') {

        if (cycleCount < totalSlides - 1) {
          // Move to next slide
          window.nextSlide();
          cycleCount++;
          console.log(`🎯 Auto-cycled to slide ${currentSlide + 1}, cycle count: ${cycleCount}`);
        } else {
          // We've shown all banners, close the modal
          console.log('🎯 All banners shown, auto-closing modal');
          clearInterval(bannerCycleInterval);
          window.closeBannerModal();
        }
      } else {
        // Modal was closed manually, clear interval
        clearInterval(bannerCycleInterval);
      }
    }, 15000); // Change slide every 15 seconds
  };

  // Function to stop auto-cycle (called when modal is closed)
  window.stopBannerAutoCycle = function() {
    if (bannerCycleInterval) {
      clearInterval(bannerCycleInterval);
      bannerCycleInterval = null;
    }
    if (bannerAutoCloseTimeout) {
      clearTimeout(bannerAutoCloseTimeout);
      bannerAutoCloseTimeout = null;
    }
  };

} catch(e) {
  console.error('🎯 Banner test error:', e);
}
</script>

<!-- Chart.js for interactive charts (Older stable version) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>

<style>
  /* Modern Customer Dashboard - Matching Admin Design Language */
  * {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  }

  .dashboard-container {
    padding: 1.5rem;
    background: #f8fafc;
    min-height: calc(100vh - 80px);
    position: relative;
  }

  .dashboard-content {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Header Section */
  .dashboard-header {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .welcome-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .welcome-content h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.5rem 0;
  }

  .welcome-content p {
    color: #64748b;
    font-size: 1rem;
    margin: 0;
  }

  .dashboard-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  /* KPI Cards - Admin Style */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .kpi-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .kpi-card:hover {
    box-shadow: 0 10px 25px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .kpi-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .kpi-info {
    flex: 1;
  }

  .kpi-label {
    font-size: 0.875rem;
    color: #64748b;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .kpi-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .kpi-change {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .kpi-change.positive {
    color: #059669;
  }

  .kpi-change.neutral {
    color: #64748b;
  }

  .kpi-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: white;
  }

  .kpi-icon.orders { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
  .kpi-icon.cart { background: linear-gradient(135deg, #f59e0b, #d97706); }
  .kpi-icon.subscriptions { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
  .kpi-icon.rewards { background: linear-gradient(135deg, #10b981, #059669); }

  /* Chart Cards - Admin Style */
  .chart-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .chart-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .chart-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
  }

  .chart-subtitle {
    font-size: 0.875rem;
    color: #64748b;
  }

  /* Quick Actions - Admin Style */
  .quick-actions {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none;
    color: #1e293b;
    transition: all 0.2s ease;
    font-weight: 500;
  }

  .action-btn:hover {
    background: #f1f5f9;
    border-color: #cbd5e1;
    color: #1e293b;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .action-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    color: white;
  }

  .btn-primary-custom {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary-custom:hover {
    background: linear-gradient(135deg, #2563eb, #1e40af);
    color: white;
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* Recent Activity Card */
  .activity-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(229, 231, 235, 0.8);
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f1f5f9;
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    color: white;
  }

  .activity-content h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0;
  }

  .activity-content p {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
  }

  /* Empty Chart Placeholder */
  .empty-chart-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 200px;
    background: #f8fafc;
    border: 2px dashed #cbd5e1;
    border-radius: 8px;
    text-align: center;
    padding: 1rem;
  }

  .empty-chart-placeholder p {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .dashboard-container {
      padding: 1rem;
    }

    .dashboard-header {
      padding: 1.5rem;
    }

    .welcome-section {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .dashboard-actions {
      width: 100%;
      justify-content: flex-start;
    }

    .kpi-grid {
      grid-template-columns: 1fr;
    }

    .chart-grid {
      grid-template-columns: 1fr;
    }

    .actions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<% if current_customer %>
<div class="dashboard-container">
  <div class="dashboard-content">

    <!-- Dashboard Header -->
    <div class="dashboard-header">
      <div class="welcome-section">
        <div class="welcome-content">
          <h1>Welcome back, <%= current_customer.first_name %>!</h1>
          <p>Here's what's happening with your account today.</p>
        </div>
        <div class="dashboard-actions">
          <%= link_to customer_shop_path, class: "btn-primary-custom" do %>
            <i class="bi bi-shop me-2"></i>Shop Now
          <% end %>
        </div>
      </div>
    </div>

    <!-- KPI Cards -->
