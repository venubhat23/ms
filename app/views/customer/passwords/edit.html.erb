<% content_for :title, "Reset Password" %>

<style>
  .password-form-container {
    max-width: 100%;
  }

  .form-label {
    color: var(--green-dark);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .password-requirements {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 5px;
  }

  .btn-reset {
    background: linear-gradient(135deg, var(--green) 0%, var(--green-mid) 100%);
    border: none;
    border-radius: 12px;
    padding: 14px 24px;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.4s ease;
    width: 100%;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .btn-reset:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(93, 130, 51, 0.3);
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: var(--dark);
  }

  .icon-container {
    background: linear-gradient(135deg, var(--green) 0%, var(--green-mid) 100%);
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
</style>

<!-- Welcome Section -->
<div class="welcome-section">
  <div class="icon-container">
    <i class="bi bi-shield-lock-fill text-white" style="font-size: 1.8rem;"></i>
  </div>
  <h2 class="welcome-title">Reset Your Password</h2>
  <p class="welcome-subtitle">Create a new secure password for your account</p>
</div>

<!-- Password Reset Form -->
<div class="password-form-container">
  <%= form_with url: customer_reset_password_path, method: :patch, local: true, id: "resetForm", class: "needs-validation", novalidate: true do |form| %>
    <%= form.hidden_field :token, value: @token %>

    <!-- New Password Field -->
    <div class="form-group">
      <%= form.label :password, "New Password", class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text">
          <i class="bi bi-lock-fill"></i>
        </span>
        <%= form.password_field :password,
            class: "form-control",
            placeholder: "Enter new password",
            required: true,
            minlength: 6,
            id: "password" %>
      </div>
      <div class="password-requirements">
        <i class="bi bi-info-circle"></i> Password must be at least 6 characters long
      </div>
    </div>

    <!-- Confirm Password Field -->
    <div class="form-group">
      <%= form.label :password_confirmation, "Confirm New Password", class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text">
          <i class="bi bi-lock-check-fill"></i>
        </span>
        <%= form.password_field :password_confirmation,
            class: "form-control",
            placeholder: "Confirm new password",
            required: true,
            id: "password_confirmation" %>
      </div>
    </div>

    <!-- Submit Button -->
    <div class="form-group">
      <%= form.submit "Update Password", class: "btn btn-reset", data: { disable_with: "Updating..." } %>
    </div>
  <% end %>
</div>

<!-- Back to Login Link -->
<div class="auth-links">
  <div class="auth-separator">
    <span>Remember your password?</span>
  </div>
  <%= link_to "Back to Sign In", customer_login_path, class: "register-link" %>
</div>

<!-- Form Validation Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('resetForm');
  const password = document.getElementById('password');
  const passwordConfirmation = document.getElementById('password_confirmation');

  // Real-time password confirmation validation
  function validatePasswordMatch() {
    if (passwordConfirmation.value !== password.value) {
      passwordConfirmation.setCustomValidity("Passwords don't match");
      passwordConfirmation.classList.add('is-invalid');
      passwordConfirmation.classList.remove('is-valid');
    } else {
      passwordConfirmation.setCustomValidity('');
      passwordConfirmation.classList.remove('is-invalid');
      passwordConfirmation.classList.add('is-valid');
    }
  }

  // Password length validation
  function validatePasswordLength() {
    if (password.value.length >= 6) {
      password.classList.remove('is-invalid');
      password.classList.add('is-valid');
    } else if (password.value.length > 0) {
      password.classList.add('is-invalid');
      password.classList.remove('is-valid');
    }
  }

  // Event listeners
  password.addEventListener('input', function() {
    validatePasswordLength();
    if (passwordConfirmation.value.length > 0) {
      validatePasswordMatch();
    }
  });

  passwordConfirmation.addEventListener('input', validatePasswordMatch);

  // Form submission validation
  form.addEventListener('submit', function(event) {
    if (password.value.length < 6) {
      event.preventDefault();
      password.focus();
      return false;
    }

    if (password.value !== passwordConfirmation.value) {
      event.preventDefault();
      passwordConfirmation.focus();
      return false;
    }

    // Disable button to prevent double submission
    const submitBtn = form.querySelector('input[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.value = 'Updating...';
  });
});
</script>