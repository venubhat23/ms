<%# Forgot Password Form %>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      <div class="card shadow-lg border-0">
        <div class="card-body p-5">
          <!-- Header -->
          <div class="text-center mb-4">
            <div class="mb-3">
              <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
            </div>
            <h2 class="card-title fw-bold text-dark">Forgot Password?</h2>
            <p class="text-muted">Enter your email address and we'll send you instructions to reset your password.</p>
          </div>

          <!-- Flash Messages -->
          <% if flash[:notice] %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <i class="bi bi-check-circle me-2"></i>
              <%= flash[:notice] %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <% if flash[:alert] %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <%= flash[:alert] %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <!-- Form -->
          <%= form_with url: customer_forgot_password_path, method: :post, local: true, class: "needs-validation", novalidate: true do |form| %>
            <div class="mb-4">
              <%= form.label :email, "Email Address", class: "form-label fw-semibold" %>
              <div class="input-group">
                <span class="input-group-text">
                  <i class="bi bi-envelope"></i>
                </span>
                <%= form.email_field :email,
                    class: "form-control form-control-lg",
                    placeholder: "Enter your email address",
                    required: true,
                    autocomplete: "email" %>
                <div class="invalid-feedback">
                  Please enter a valid email address.
                </div>
              </div>
            </div>

            <div class="d-grid mb-4">
              <%= form.submit "Send Reset Instructions",
                  class: "btn btn-primary btn-lg fw-semibold",
                  data: { disable_with: "Sending..." } %>
            </div>
          <% end %>

          <!-- Back to Login -->
          <div class="text-center">
            <p class="text-muted mb-0">
              Remember your password?
              <%= link_to "Sign In", customer_login_path,
                  class: "text-primary text-decoration-none fw-semibold" %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Bootstrap Form Validation -->
<script>
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>

<style>
  .card {
    border-radius: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
  }

  .form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
  }

  .input-group-text {
    background: #f8f9fa;
    border-color: #dee2e6;
  }
</style>