<% content_for :title, 'Customer Registration' %>

<div class="welcome-text">
  <h1 class="welcome-title">Join Marali Santhe</h1>
  <p class="welcome-subtitle">Create your account and start your organic journey</p>
</div>

<%= form_with model: @customer, url: customer_register_path, local: true, class: "needs-validation", novalidate: true do |f| %>
  <% if @customer&.errors&.any? %>
    <div class="alert alert-danger">
      <h6><i class="bi bi-exclamation-triangle me-2"></i>Please fix the following errors:</h6>
      <ul class="mb-0">
        <% @customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6">
      <div class="form-group">
        <%= f.label :first_name, "First Name", class: "form-label" %>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person"></i></span>
          <%= f.text_field :first_name,
                          class: "form-control #{'is-invalid' if @customer&.errors&.[](:first_name)&.any?}",
                          placeholder: "Enter first name",
                          required: true,
                          autofocus: true %>
          <div class="invalid-feedback">
            <%= @customer&.errors&.[](:first_name)&.first || "Please enter your first name." %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="form-group">
        <%= f.label :last_name, "Last Name", class: "form-label" %>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person-check"></i></span>
          <%= f.text_field :last_name,
                          class: "form-control #{'is-invalid' if @customer&.errors&.[](:last_name)&.any?}",
                          placeholder: "Enter last name",
                          required: true %>
          <div class="invalid-feedback">
            <%= @customer&.errors&.[](:last_name)&.first || "Please enter your last name." %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :email, "Email Address", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-envelope"></i></span>
      <%= f.email_field :email,
                        class: "form-control #{'is-invalid' if @customer&.errors&.[](:email)&.any?}",
                        placeholder: "Enter email address",
                        required: true %>
      <div class="invalid-feedback">
        <%= @customer&.errors&.[](:email)&.first || "Please enter a valid email address." %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :mobile, "Mobile Number", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-telephone"></i></span>
      <%= f.text_field :mobile,
                      class: "form-control #{'is-invalid' if @customer&.errors&.[](:mobile)&.any?}",
                      placeholder: "Enter 10-digit mobile number",
                      pattern: "[6-9][0-9]{9}",
                      required: true %>
      <div class="invalid-feedback">
        <%= @customer&.errors&.[](:mobile)&.first || "Please enter a valid 10-digit mobile number." %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :password, "Password", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
      <%= f.password_field :password,
                          class: "form-control #{'is-invalid' if @customer&.errors&.[](:password)&.any?}",
                          placeholder: "Create a password (min 6 characters)",
                          minlength: "6",
                          required: true %>
      <div class="invalid-feedback">
        <%= @customer&.errors&.[](:password)&.first || "Password must be at least 6 characters long." %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
      <%= f.password_field :password_confirmation,
                          class: "form-control #{'is-invalid' if @customer&.errors&.[](:password_confirmation)&.any?}",
                          placeholder: "Confirm your password",
                          required: true %>
      <div class="invalid-feedback">
        <%= @customer&.errors&.[](:password_confirmation)&.first || "Passwords must match." %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :address, "Address (Optional)", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
      <%= f.text_area :address,
                     class: "form-control",
                     rows: 2,
                     placeholder: "Enter your address" %>
    </div>
  </div>

  <div class="form-group">
    <div class="form-check">
      <input type="checkbox" class="form-check-input" id="terms" required>
      <label class="form-check-label" for="terms">
        I agree to the <a href="#" class="text-decoration-none">Terms & Conditions</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
      </label>
      <div class="invalid-feedback">
        You must agree to the terms and conditions.
      </div>
    </div>
  </div>

  <div class="d-grid gap-2 mb-4">
    <%= f.submit "Create Account", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>

<div class="auth-links">
  <div class="auth-separator">
    <span>or</span>
  </div>
  <p class="mb-0">
    Already have an account?
    <%= link_to customer_login_path do %>
      <i class="bi bi-box-arrow-in-right me-1"></i>Sign in here
    <% end %>
  </p>
  <div class="organic-features mt-4">
    <div class="feature-badge">
      <i class="bi bi-award"></i>
      <span>100% Natural</span>
    </div>
    <div class="feature-badge">
      <i class="bi bi-shield-check"></i>
      <span>Safe & Secure</span>
    </div>
    <div class="feature-badge">
      <i class="bi bi-people"></i>
      <span>Community</span>
    </div>
  </div>
</div>

<script>
  // Bootstrap form validation
  (function() {
    'use strict';
    window.addEventListener('load', function() {
      var forms = document.getElementsByClassName('needs-validation');
      var validation = Array.prototype.filter.call(forms, function(form) {
        form.addEventListener('submit', function(event) {
          if (form.checkValidity() === false) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    }, false);
  })();

  // Password confirmation validation
  document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('customer_password');
    const confirmPassword = document.getElementById('customer_password_confirmation');

    function validatePassword() {
      if (password.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity('Passwords must match');
      } else {
        confirmPassword.setCustomValidity('');
      }
    }

    password.addEventListener('change', validatePassword);
    confirmPassword.addEventListener('keyup', validatePassword);
  });
</script>