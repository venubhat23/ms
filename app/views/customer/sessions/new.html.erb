<% content_for :title, 'Customer Login' %>

<div class="welcome-text">
  <h1 class="welcome-title">Welcome Back!</h1>
  <p class="welcome-subtitle">Sign in to continue to your organic journey with Marali Santhe</p>
</div>

<%= form_with url: customer_login_path, method: :post, local: true, class: "needs-validation", novalidate: true do |f| %>
  <div class="form-group">
    <%= f.label :email_or_mobile, "Email or Mobile Number", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-person-circle"></i></span>
      <%= f.text_field :email_or_mobile,
                      class: "form-control",
                      placeholder: "Enter your email or mobile number",
                      required: true,
                      autofocus: true %>
      <div class="invalid-feedback">
        Please enter your email or mobile number.
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :password, "Password", class: "form-label" %>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
      <%= f.password_field :password,
                          class: "form-control",
                          placeholder: "Enter your password",
                          required: true %>
      <div class="invalid-feedback">
        Please enter your password.
      </div>
    </div>
  </div>

  <div class="form-group d-flex justify-content-between align-items-center">
    <div class="form-check">
      <%= f.check_box :remember_me, class: "form-check-input" %>
      <%= f.label :remember_me, "Keep me signed in", class: "form-check-label" %>
    </div>
    <%= link_to customer_forgot_password_path, class: "text-decoration-none", style: "color: var(--green); font-weight: 600;" do %>
      <i class="bi bi-key me-1"></i>Forgot password?
    <% end %>
  </div>

  <div class="d-grid gap-2 mb-4">
    <%= f.submit "Sign In to Account", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>

<div class="auth-links">
  <p class="mb-0">
    New to Marali Santhe?
    <%= link_to customer_register_path do %>
      <i class="bi bi-person-plus me-1"></i>Create an account
    <% end %>
  </p>
</div>

<script>
  // Bootstrap form validation
  (function() {
    'use strict';
    window.addEventListener('load', function() {
      var forms = document.getElementsByClassName('needs-validation');
      var validation = Array.prototype.filter.call(forms, function(form) {
        form.addEventListener('submit', function(event) {
          if (form.checkValidity() === false) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    }, false);
  })();
</script>