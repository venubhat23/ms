function updateOrderSummary(cart) {
  const orderItemsContainer = document.getElementById('orderItems');
  const subtotalElement = document.getElementById('orderSubtotal');
  const totalElement = document.getElementById('orderTotal');

  let subtotal = 0;
  let totalGST = 0;
  let itemsHtml = '';

  cart.forEach(item => {
    const itemTotal = item.price * item.quantity;
    subtotal += itemTotal;

    // Calculate GST for this item - use proper rounding like the product display
    const itemFinalPrice = item.price;
    const itemGSTRate = item.gstRate || 0;

    if (itemGSTRate > 0) {
      // Use the same smart rounding logic as in the product cards
      const roundedFinal = itemFinalPrice;
      const roundedBase = Math.round(roundedFinal / (1 + (itemGSTRate / 100.0)));
      const roundedGST = roundedFinal - roundedBase;
      const itemGSTAmount = roundedGST * item.quantity;
      totalGST += itemGSTAmount;

      itemsHtml += `
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div>
            <strong>${item.name}</strong><br>
            <small class="text-muted">₹${roundedBase} + GST ${itemGSTRate}%</small><br>
            <small class="text-muted">Only ${item.maxStock} in stock</small>
          </div>
          <div class="text-end">
            <strong>${item.quantity}</strong><br>
            <span>₹${itemTotal.toFixed(2)}</span>
          </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <small class="text-muted">${item.quantity} × ₹${roundedBase.toFixed(2)} (base)</small>
          <div></div>
        </div>
      `;
    } else {
      itemsHtml += `
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div>
            <strong>${item.name}</strong> × ${item.quantity}
            <small class="text-muted d-block">₹${item.price} each</small>
          </div>
          <span>₹${itemTotal.toFixed(2)}</span>
        </div>
      `;
    }
  });

  // Calculate base amount (total - GST)
  const baseAmount = subtotal - totalGST;

  orderItemsContainer.innerHTML = itemsHtml;

  // Update summary with proper GST breakdown
  const summaryHtml = `
    <div class="d-flex justify-content-between">
      <strong>Subtotal</strong>
      <strong>₹${baseAmount.toFixed(2)}</strong>
    </div>
    <div class="d-flex justify-content-between">
      <span>GST</span>
      <span>₹${totalGST.toFixed(2)}</span>
    </div>
    <div class="d-flex justify-content-between">
      <span>Delivery:</span>
      <span id="orderDelivery">Free</span>
    </div>
    <hr>
    <div class="d-flex justify-content-between fs-5">
      <strong>Total:</strong>
      <strong>₹${subtotal.toFixed(2)}</strong>
    </div>
  `;

  // Replace the existing subtotal/total section
  const orderSummary = document.querySelector('.order-summary');
  const existingItemsDiv = orderSummary.querySelector('#orderItems');

  // Clear everything after the items
  let nextElement = existingItemsDiv.nextSibling;
  while (nextElement) {
    const elementToRemove = nextElement;
    nextElement = nextElement.nextSibling;
    if (elementToRemove.nodeType === 1 || elementToRemove.nodeType === 3) {
      elementToRemove.remove();
    }
  }

  // Add the new summary
  existingItemsDiv.insertAdjacentHTML('afterend', summaryHtml);

  orderTotal = subtotal;

  // Update pay button text
  updatePayButtonText();
}

