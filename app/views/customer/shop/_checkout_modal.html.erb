        customer_name: getCurrentCustomerName(),
        customer_email: getCurrentCustomerEmail(),
        customer_phone: getCurrentCustomerPhone(),
        delivery_address: getSelectedDeliveryInfo(deliveryInfo),
        delivery_method: deliveryInfo.type,
        delivery_store: deliveryInfo.type === 'pickup' ? getSelectedPickupLocation(deliveryInfo.location) : null,
        payment_method: 'cod'
      })
    });

    console.log('COD Response Status:', response.status);

    if (!response.ok) {
      const errorText = await response.text();
      console.error('COD Response Error Text:', errorText);
      throw new Error(`HTTP ${response.status}: ${errorText}`);
    }

    const data = await response.json();
    console.log('COD Response Data:', data);

    if (data.success) {
      // Update loader to show completion
      updateProgressStep(3, 'Order Confirmed Successfully!', 100);

      // Clear cart
      localStorage.removeItem('customerCart');

      // Give user time to see the success before redirecting
      setTimeout(() => {
        // Hide the loader
        hideOrderProcessingLoader();

        // Show success message
        alert('Order placed successfully! Order Number: ' + (data.booking_number || data.booking_id));

        // Redirect
        window.location.href = data.redirect_url || '/customer/dashboard';
      }, 1500);

      return; // Exit early to avoid the rest of the code

      // Close modal safely (this won't be reached due to return above)
      try {
        const modalElement = document.getElementById('checkoutModal');
        if (modalElement) {
          const modal = bootstrap.Modal.getInstance(modalElement);
          if (modal) {
            modal.hide();
          } else {
            // If no instance exists, create one and hide it
            const newModal = new bootstrap.Modal(modalElement);
            newModal.hide();
          }
        }
      } catch (modalError) {
        console.warn('Could not close modal:', modalError);
        // Continue with success flow even if modal can't be closed
      }

      // Show success message
      alert('Order placed successfully! Order Number: ' + (data.booking_number || data.booking_id));

      // Restore button state before redirect
      const payBtn = document.getElementById('payNowBtn');
      if (payBtn && payBtn.originalContent) {
        restoreButtonState(payBtn, payBtn.originalContent);
      }

      // Redirect using the redirect URL from response or default to dashboard
      window.location.href = data.redirect_url || '/customer/dashboard';
    } else {
      throw new Error(data.error || data.message || 'Failed to place order');
    }

  } catch (error) {
    console.error('❌ COD order error:', error);
    throw error;
  }
}

