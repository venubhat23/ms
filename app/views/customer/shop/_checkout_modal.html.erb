// Helper functions to get customer data
function getCurrentCustomerName() {
  // Get from the selected address card or form
  const selectedCard = document.querySelector('.address-card.selected strong');
  return selectedCard ? selectedCard.textContent : 'Customer Name';
}

function getCurrentCustomerEmail() {
  // This should be populated from the logged-in customer session
  // For now, return a placeholder - this will be handled by the backend
  return '<%= current_customer&.email || "customer@example.com" %>';
}

function getCurrentCustomerPhone() {
  // Get from the selected address card
  const selectedCard = document.querySelector('.address-card.selected small');
  if (selectedCard) {
    const phoneMatch = selectedCard.textContent.match(/📞\s*([\d\+\-\s\(\)]+)/);
    return phoneMatch ? phoneMatch[1].trim() : '9876543210';
  }
  return '9876543210';
}

function getSelectedDeliveryInfo(deliveryInfo) {
  if (deliveryInfo.type === 'pickup') {
    return getSelectedPickupLocation(deliveryInfo.location);
  } else {
    return getSelectedAddress();
  }
}

function getSelectedPickupLocation(shopIndex) {
  const shopCard = document.querySelector(`#shopSelection .address-card[data-shop-index="${shopIndex}"]`);
  if (shopCard) {
    const labelElement = shopCard.querySelector('label');
    if (labelElement) {
      // Extract shop address text
      const shopText = labelElement.innerHTML
        .replace(/<strong>.*?<\/strong><br>/, '') // Remove shop name
        .replace(/<small.*?<\/small>/, '') // Remove additional info
        .replace(/<br>/g, ', ') // Replace br with commas
        .trim();
      return shopText;
    }
  }
  return 'Shop location not selected';
}

function getSelectedAddress() {
  const selectedCard = document.querySelector('#addressSelection .address-card.selected');
  if (selectedCard) {
    const labelElement = selectedCard.querySelector('label');
    if (labelElement) {
      // Extract address text excluding the strong tag
      const addressText = labelElement.innerHTML
        .replace(/<strong>.*?<\/strong><br>/, '') // Remove address type
        .replace(/<small.*?<\/small>/, '') // Remove phone number
        .replace(/<br>/g, '') // Remove br tags
        .trim();
      return addressText;
    }
  }
  return 'Address not selected';
}

// Add event listener for cart checkout button
document.addEventListener('DOMContentLoaded', function() {
  // If there's a checkout button in the UI, bind it to showCheckout
  const checkoutBtn = document.getElementById('checkoutBtn');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', showCheckout);
  }

  // Add delivery method selection event listeners
  document.addEventListener('click', function(e) {
    const deliveryOption = e.target.closest('.delivery-method-selection .payment-option');
    if (deliveryOption && deliveryOption.dataset.method) {
      e.preventDefault();
      e.stopPropagation();
      selectDeliveryMethod(deliveryOption.dataset.method);
    }
  });

  // Also handle radio button changes for delivery method
  const deliveryRadioButtons = document.querySelectorAll('input[name="delivery_method"]');
  deliveryRadioButtons.forEach(radio => {
    radio.addEventListener('change', function() {
      if (this.checked) {
        selectDeliveryMethod(this.value);
      }
    });
  });

  // Ensure our payment button has the correct handler
  const payNowBtn = document.getElementById('payNowBtn');
  if (payNowBtn) {
    // Remove any existing event listeners and add our specific one
    payNowBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      console.log('🎯 PayNow button clicked - using Cashfree integration');
      processPayment();
      return false;
    }, true); // Use capture phase to ensure it runs first
  }
});

// Override any global functions that might conflict
