async function processPayment() {
  console.log('🚀🚀🚀 CASHFREE PAYMENT PROCESS STARTED 🚀🚀🚀');

  const payBtn = document.getElementById('payNowBtn');

  // Store original content BEFORE showing the loader
  const originalContent = payBtn.innerHTML;
  if (!payBtn.originalContent) {
    payBtn.originalContent = originalContent;
  }

  // Show the attractive order processing loader
  showOrderProcessingLoader();

  console.log('🚀 Starting payment process...');
  console.log('PaymentSystem.selectedMethod:', PaymentSystem.selectedMethod);
  console.log('selectedPaymentMethod:', selectedPaymentMethod);

  // Prevent any other handlers from running
  window.event?.stopImmediatePropagation?.();
  window.event?.preventDefault?.();

  // FIXED: Get cart and delivery data with proper cleanup
  const cart = getCleanCart();

  // Validate based on delivery method
  let deliveryInfo = null;

  if (selectedDeliveryMethod === 'pickup') {
    const selectedShop = document.querySelector('input[name="pickup_location"]:checked');
    if (!selectedShop) {
      alert('Please select a pickup location');
      restoreButtonState(payBtn, originalContent);
      return;
    }
    deliveryInfo = {
      type: 'pickup',
      location: selectedShop.value
    };
  } else {
    const selectedAddress = document.querySelector('input[name="delivery_address"]:checked');
    if (!selectedAddress) {
      alert('Please select a delivery address');
      restoreButtonState(payBtn, originalContent);
      return;
    }
    deliveryInfo = {
      type: 'home',
      address: selectedAddress.value
    };
  }

  if (cart.length === 0) {
    alert('Your cart is empty');
    restoreButtonState(payBtn, originalContent);
    return;
  }

  // Hide payment method selection and show processing state
  hidePaymentMethodsAndShowProcessing();

  // Show loading with proper button disabled state
  const currentMethod = PaymentSystem.selectedMethod || selectedPaymentMethod || 'cod';
  if (currentMethod === 'cod') {
    payBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Placing Order...';
  } else {
    payBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing Payment...';
  }

  payBtn.disabled = true;
  payBtn.setAttribute('disabled', 'disabled');

  // Ensure button is visually disabled with multiple approaches
  payBtn.style.pointerEvents = 'none';
  payBtn.style.opacity = '0.7';
  payBtn.style.background = '#6c757d';
  payBtn.style.cursor = 'not-allowed';
  payBtn.classList.add('disabled');

  // Add loading animation to button
  payBtn.style.transition = 'all 0.3s ease';
  payBtn.style.transform = 'scale(0.98)';

  // Prevent multiple clicks during processing
  payBtn.onclick = function(e) {
    e.preventDefault();
    e.stopPropagation();
    return false;
  };

  console.log('💳 Button disabled, starting payment flow...');

  try {
    // Get the currently selected payment method from radio buttons
    const selectedRadio = document.querySelector('input[name="payment_method"]:checked');
    const currentMethod = selectedRadio ? selectedRadio.value : 'cashfree';

    console.log('🎯 Selected payment method from radio:', currentMethod);
    console.log('🎯 PaymentSystem.selectedMethod:', PaymentSystem.selectedMethod);
    console.log('🎯 selectedPaymentMethod variable:', selectedPaymentMethod);
    console.log('🎯 Radio button found:', selectedRadio ? 'YES' : 'NO');
    console.log('🎯 All payment method radios:', document.querySelectorAll('input[name="payment_method"]'));

    // Force to use the selected radio button value or default to cashfree
    const finalMethod = selectedRadio ? selectedRadio.value : 'cashfree';
    console.log('🎯 FINAL METHOD TO USE:', finalMethod);

    // Handle both cashfree and upi as online payment methods
    if (finalMethod === 'cashfree' || finalMethod === 'upi') {
      console.log('🎯 Will route to: Cashfree Payment Gateway');
      await processCashfreePayment(cart, deliveryInfo);
    } else if (finalMethod === 'cod') {
      console.log('🎯 Will route to: COD Order');
      await processCODOrder(cart, deliveryInfo);
    } else {
      console.log('🎯 Unknown payment method, defaulting to Cashfree');
      await processCashfreePayment(cart, deliveryInfo);
    }
  } catch (error) {
    console.error('❌ Payment processing error:', error);

    // Hide the order processing loader
    hideOrderProcessingLoader();

    // Show error message
    alert('Payment failed. Please try again.');

    // Reset UI
    showPaymentMethodsAndHideProcessing();
    restoreButtonState(payBtn, originalContent);
  }
}

async function processCashfreePayment(cart, deliveryInfo) {
  console.log('🚀 processCashfreePayment called!');
  console.log('🛒 Cart items:', cart.length);
  console.log('📍 Delivery info:', deliveryInfo);

  try {
    // Debug CSRF token
    const csrfToken = document.querySelector('meta[name="csrf-token"]');
    console.log('CSRF Token meta tag found:', csrfToken ? 'YES' : 'NO');
    console.log('CSRF Token value:', csrfToken ? csrfToken.getAttribute('content') : 'N/A');

    if (!csrfToken || !csrfToken.getAttribute('content')) {
      throw new Error('CSRF token not found. Please refresh the page and try again.');
    }

    console.log('💳 Making request to /customer/checkout/cart_order...');

    // Prepare cart data in format expected by cart_order endpoint
    const cartData = cart.map(item => ({
      id: item.id,
      quantity: item.quantity,
      price: item.price,
      name: item.name
    }));

    // Create order using customer checkout cart_order endpoint
    const orderResponse = await fetch('/customer/checkout/cart_order', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken.getAttribute('content')
      },
      body: JSON.stringify({
        cart_data: cartData,
        customer_name: getCurrentCustomerName(),
        customer_email: getCurrentCustomerEmail(),
        customer_phone: getCurrentCustomerPhone(),
        delivery_address: getSelectedDeliveryInfo(deliveryInfo),
        delivery_method: deliveryInfo.type,
        delivery_store: deliveryInfo.type === 'pickup' ? getSelectedPickupLocation(deliveryInfo.location) : null,
        payment_method: 'cashfree'
      })
    });

    console.log('Order Response Status:', orderResponse.status);
    console.log('Order Response Headers:', Object.fromEntries(orderResponse.headers.entries()));

    if (!orderResponse.ok) {
      const errorText = await orderResponse.text();
      console.error('Order Response Error Text:', errorText);
      throw new Error(`HTTP ${orderResponse.status}: ${errorText}`);
    }

    const orderData = await orderResponse.json();
    console.log('Order Response Data:', orderData);

    if (!orderData.success) {
      throw new Error(orderData.error || orderData.message || 'Failed to create order');
    }

    // Check if this is a Cashfree payment that needs redirection
    if (orderData.redirect_to_payment && orderData.payment_session_id) {
      console.log('🎯 Redirecting to Cashfree payment gateway...');

      // Initialize Cashfree payment
      if (!cashfree) {
        try {
          await initializeCashfree();
          if (!cashfree) {
            throw new Error('Cashfree SDK failed to initialize');
          }
        } catch (initError) {
          console.error('❌ Failed to initialize Cashfree SDK:', initError);
          throw new Error('Payment gateway initialization failed');
        }
      }

      const checkoutOptions = {
        paymentSessionId: orderData.payment_session_id,
        redirectTarget: '_self'
      };

      // Open Cashfree checkout
      try {
        // Update loader to show payment gateway opening
        updateProgressStep(3, 'Opening Payment Gateway...', 100);

        await cashfree.checkout(checkoutOptions);
        console.log('✅ Payment gateway opened successfully');

        // The loader will disappear when user is redirected to payment gateway
        // No need to manually hide it as the page will navigate away

      } catch (checkoutError) {
        console.error('❌ Cashfree checkout error:', checkoutError);
        throw new Error('Failed to open payment gateway: ' + checkoutError.message);
      }
    } else {
      // This shouldn't happen for Cashfree payments, but handle gracefully
      throw new Error('Payment session not created properly');
    }

  } catch (error) {
    console.error('❌ Cashfree payment error:', error);
    throw error;
  }
}

