<!DOCTYPE html>
<html lang="en">
<head>
  <title>Franchise Login - Marali Santhe</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <!-- Poppins Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- Enhanced Centered Login Page -->
<div class="enhanced-login-wrapper">
  <div class="enhanced-login-container">
    <div class="enhanced-login-card">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="alert alert-success mb-3">
          <i class="fas fa-check-circle me-2"></i><%= notice %>
        </div>
      <% end %>

      <% if alert && alert.present? && alert.strip != "" %>
        <div class="alert alert-danger mb-3">
          <i class="fas fa-exclamation-triangle me-2"></i><%= alert %>
        </div>
      <% end %>

      <!-- Logo Section -->
      <div class="text-center mb-4">
        <div class="enhanced-logo">
          <div class="logo-container franchise-logo">
            <%= image_tag "logo.jpeg", alt: "Marali Santhe Logo", class: "franchise-logo-img" %>
          </div>
        </div>
        <h2 class="enhanced-title">Marali Santhe</h2>
      </div>

      <!-- Enhanced Login Form -->
      <%= form_with model: @franchise, url: franchise_login_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :email, "Email", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">
              <i class="fas fa-envelope"></i>
            </span>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "email@example.com" %>
          </div>
          <small class="text-muted">Please enter your franchise email address</small>
        </div>

        <div class="mb-3">
          <%= f.label :password, "Password", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">
              <i class="fas fa-lock"></i>
            </span>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "••••••••" %>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="form-check">
            <input type="checkbox" class="form-check-input" id="remember_me" name="remember_me">
            <label class="form-check-label" for="remember_me">Remember me</label>
          </div>
        </div>

        <%= f.submit "SIGN IN", class: "btn btn-primary w-100 py-3 fs-5 fw-semibold" %>
      <% end %>

    </div>
  </div>
</div>

<!-- Enhanced Login Styles -->
<style>
body {
  font-family: 'Poppins', sans-serif !important;
  margin: 0 !important;
  padding: 0 !important;
  height: 100vh !important;
  overflow: hidden !important;
}

.enhanced-login-wrapper {
  min-height: 100vh !important;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  position: relative !important;
  overflow: hidden !important;
}

.enhanced-login-wrapper::before {
  content: '' !important;
  position: absolute !important;
  top: -50% !important;
  left: -50% !important;
  width: 200% !important;
  height: 200% !important;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%) !important;
  animation: float 6s ease-in-out infinite !important;
}

.enhanced-login-container {
  z-index: 10 !important;
  position: relative !important;
}

.enhanced-login-card {
  background: rgba(255, 255, 255, 0.95) !important;
  backdrop-filter: blur(20px) !important;
  border-radius: 24px !important;
  padding: 3rem !important;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25) !important;
  border: 1px solid rgba(255, 255, 255, 0.3) !important;
  width: 100% !important;
  max-width: 420px !important;
  animation: slideUp 0.8s ease-out !important;
}

.enhanced-logo {
  margin-bottom: 1.5rem !important;
}

.logo-container {
  width: 80px !important;
  height: 80px !important;
  background: linear-gradient(135deg, #4ade80 0%, #22d3ee 100%) !important;
  border-radius: 20px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin: 0 auto !important;
  box-shadow: 0 10px 30px rgba(74, 222, 128, 0.4) !important;
  transition: transform 0.3s ease !important;
}

/* Franchise-specific orange gradient for logo */
.logo-container.franchise-logo {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%) !important;
  box-shadow: 0 10px 30px rgba(249, 115, 22, 0.4) !important;
}

.franchise-logo-img {
  width: 50px;
  height: 50px;
  object-fit: contain;
  border-radius: 12px;
}

.logo-container:hover {
  transform: scale(1.05) rotate(5deg) !important;
}

.logo-container i {
  font-size: 2.5rem !important;
  color: white !important;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3) !important;
}

.enhanced-title {
  color: #6366f1 !important;
  font-weight: 700 !important;
  font-size: 1.8rem !important;
  margin-bottom: 0 !important;
  text-shadow: 0 2px 10px rgba(99, 102, 241, 0.3) !important;
}

.form-label {
  font-weight: 600 !important;
  color: #374151 !important;
  margin-bottom: 0.5rem !important;
}

.input-group-text {
  background: linear-gradient(135deg, #f8fafc, #e2e8f0) !important;
  border: 2px solid #e5e7eb !important;
  border-right: none !important;
  color: #6b7280 !important;
  transition: all 0.3s ease !important;
}

.form-control {
  border: 2px solid #e5e7eb !important;
  border-left: none !important;
  padding: 0.75rem 1rem !important;
  font-size: 1rem !important;
  transition: all 0.3s ease !important;
  background: rgba(255, 255, 255, 0.9) !important;
}

.form-control:focus {
  border-color: #6366f1 !important;
  box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.25) !important;
  outline: none !important;
}

.form-control:focus + .input-group-text,
.input-group .form-control:focus ~ .input-group-text {
  border-color: #6366f1 !important;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.1)) !important;
  color: #6366f1 !important;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%) !important;
  border: none !important;
  border-radius: 16px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 1px !important;
  transition: all 0.3s ease !important;
  box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4) !important;
}

.btn-primary:hover {
  background: linear-gradient(135deg, #5b61eb, #8350f3) !important;
  transform: translateY(-2px) !important;
  box-shadow: 0 15px 35px rgba(99, 102, 241, 0.6) !important;
}

.form-check-input:checked {
  background-color: #6366f1 !important;
  border-color: #6366f1 !important;
}

.form-check-label {
  color: #6b7280 !important;
  font-weight: 500 !important;
}

.text-muted {
  color: #9ca3af !important;
  font-size: 0.875rem !important;
}

.alert {
  border-radius: 12px !important;
  border: none !important;
  font-weight: 500 !important;
}

.alert-success {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(74, 222, 128, 0.1)) !important;
  color: #166534 !important;
  border: 1px solid rgba(34, 197, 94, 0.2) !important;
}

.alert-danger {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(248, 113, 113, 0.1)) !important;
  color: #991b1b !important;
  border: 1px solid rgba(239, 68, 68, 0.2) !important;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes float {
  0%, 100% {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  50% {
    transform: translate(-50%, -50%) rotate(180deg);
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .enhanced-login-card {
    margin: 1rem !important;
    padding: 2rem !important;
    border-radius: 20px !important;
  }

  .enhanced-title {
    font-size: 1.5rem !important;
  }

  .logo-container {
    width: 70px !important;
    height: 70px !important;
  }

  .logo-container i {
    font-size: 2rem !important;
  }
}
</style>

</body>
</html>