<style>
/* Modern Customer Sidebar - Perfectly Matching Admin Design */
.customer-sidebar {
  position: fixed !important;
  top: 80px !important;
  left: 0 !important;
  width: 200px !important;
  height: calc(100vh - 80px) !important;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 50%, #f1f5f9 100%) !important;
  border-right: 2px solid #e2e8f0 !important;
  z-index: 1040 !important;
  overflow: hidden !important;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important;
  display: flex !important;
  flex-direction: column !important;
  backdrop-filter: blur(10px) !important;
  transform: translateX(0) !important;
  transition: transform 0.3s ease !important;
}

@media (max-width: 991.98px) {
  .customer-sidebar {
    transform: translateX(-100%) !important;
  }

  .customer-sidebar.sidebar-open {
    transform: translateX(0) !important;
  }
}

/* Modern Navigation Link - Based on Admin Design */
.customer-nav-link-modern {
  display: flex !important;
  align-items: center !important;
  padding: 10px 16px !important;
  margin: 4px 8px !important;
  border-radius: 16px !important;
  color: #64748b !important;
  font-weight: 500 !important;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  background: rgba(248, 250, 252, 0.8) !important;
  border: 1px solid rgba(226, 232, 240, 0.8) !important;
}

.customer-nav-link-modern::before {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  top: 0 !important;
  width: 4px !important;
  height: 100% !important;
  background: linear-gradient(to bottom, #10b981, #34d399) !important;
  transform: scaleY(0) !important;
  transition: transform 0.3s ease !important;
}

.customer-nav-link-modern:hover {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(52, 211, 153, 0.1) 100%) !important;
  color: #1e293b !important;
  transform: translateY(-2px) !important;
  box-shadow: 0 12px 30px rgba(16, 185, 129, 0.15) !important;
  border: 1px solid rgba(16, 185, 129, 0.2) !important;
}

.customer-nav-link-modern:hover::before {
  transform: scaleY(1) !important;
}

.customer-nav-link-modern:hover .customer-nav-text {
  color: #1e293b !important;
  font-weight: 600 !important;
}

.customer-nav-link-modern.active {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%) !important;
  color: #ffffff !important;
  box-shadow: 0 12px 30px rgba(16, 185, 129, 0.3) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  transform: translateY(-2px) !important;
}

.customer-nav-link-modern.active::before {
  transform: scaleY(1) !important;
  background: rgba(255, 255, 255, 0.3) !important;
}

.customer-nav-link-modern.active .customer-nav-text {
  color: #ffffff !important;
  font-weight: 600 !important;
}

.customer-nav-link-modern.active .customer-icon-bg {
  background: rgba(255, 255, 255, 0.2) !important;
  box-shadow: 0 4px 15px rgba(255, 255, 255, 0.3) !important;
}

.customer-nav-text {
  color: #64748b !important;
  font-weight: 500 !important;
  margin-left: 12px !important;
  font-size: 14px !important;
  display: inline-block !important;
  transition: all 0.3s ease !important;
}

/* Section Title - Based on Admin Design */
.customer-nav-section-title {
  color: #10b981 !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 1px !important;
  padding: 16px 20px 6px 20px !important;
  margin-bottom: 8px !important;
  position: relative !important;
}

.customer-nav-section-title::after {
  content: '' !important;
  position: absolute !important;
  bottom: 0 !important;
  left: 20px !important;
  width: 60px !important;
  height: 3px !important;
  background: linear-gradient(to right, #10b981, #34d399) !important;
  border-radius: 2px !important;
}

/* Icon Background - Based on Admin Design */
.customer-icon-bg {
  width: 36px !important;
  height: 36px !important;
  border-radius: 10px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: all 0.3s ease !important;
  position: relative !important;
}

.customer-icon-bg::after {
  content: '' !important;
  position: absolute !important;
  inset: 1px !important;
  border-radius: 9px !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  transition: all 0.3s ease !important;
}

.customer-nav-link-modern:hover .customer-icon-bg {
  transform: scale(1.1) rotate(2deg) !important;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3) !important;
}

.customer-nav-link-modern:hover .customer-icon-bg::after {
  border-color: rgba(255, 255, 255, 0.3) !important;
}

.customer-nav-link-modern.active .customer-icon-bg {
  transform: scale(1.1) !important;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4) !important;
}

.customer-nav-link-modern.active .customer-icon-bg::after {
  border-color: rgba(255, 255, 255, 0.4) !important;
}

/* Gradient Backgrounds for Icons - Based on Admin Design */
.customer-gradient-green {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%) !important;
  box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4) !important;
}
.customer-gradient-emerald {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%) !important;
  box-shadow: 0 6px 20px rgba(5, 150, 105, 0.4) !important;
}
.customer-gradient-teal {
  background: linear-gradient(135deg, #14b8a6 0%, #2dd4bf 100%) !important;
  box-shadow: 0 6px 20px rgba(20, 184, 166, 0.4) !important;
}
.customer-gradient-blue {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%) !important;
  box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4) !important;
}
.customer-gradient-purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%) !important;
  box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4) !important;
}
.customer-gradient-orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%) !important;
  box-shadow: 0 6px 20px rgba(249, 115, 22, 0.4) !important;
}
.customer-gradient-cyan {
  background: linear-gradient(135deg, #06b6d4 0%, #22d3ee 100%) !important;
  box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4) !important;
}
.customer-gradient-red {
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%) !important;
  box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4) !important;
}

/* Layout Structure */
.customer-sidebar-nav {
  padding: 1rem 0 !important;
  flex: 1 !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
}

.customer-nav-section {
  margin-bottom: 1.5rem !important;
}

.customer-nav-menu {
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

.customer-nav-item {
  margin-bottom: 4px !important;
}

/* User Profile Section */
.customer-user-profile-modern {
  display: flex !important;
  align-items: center !important;
  padding: 1.5rem !important;
  border-bottom: 1px solid #e2e8f0 !important;
  background: rgba(248, 250, 252, 0.8) !important;
  backdrop-filter: blur(10px) !important;
}

.customer-avatar-circle {
  width: 40px !important;
  height: 40px !important;
  border-radius: 50% !important;
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  color: white !important;
  margin-right: 12px !important;
  font-weight: 700 !important;
  font-size: 18px !important;
  box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3) !important;
}

.customer-user-name {
  color: #1e293b !important;
  font-weight: 600 !important;
  font-size: 14px !important;
  margin: 0 !important;
}

/* Footer Section */
.customer-sidebar-footer {
  margin-top: auto !important;
  padding: 1rem !important;
  border-top: 1px solid #e2e8f0 !important;
  position: relative !important;
  flex-shrink: 0 !important;
  background: rgba(248, 250, 252, 0.8) !important;
  backdrop-filter: blur(10px) !important;
}

.customer-sidebar-footer::before {
  content: '' !important;
  position: absolute !important;
  top: 0 !important;
  left: 20% !important;
  width: 60% !important;
  height: 2px !important;
  background: linear-gradient(to right, transparent, #10b981, #34d399, transparent) !important;
}

.customer-logout-btn-modern {
  display: flex !important;
  align-items: center !important;
  padding: 12px 16px !important;
  border-radius: 12px !important;
  color: #f87171 !important;
  text-decoration: none !important;
  width: 100% !important;
  transition: all 0.3s ease !important;
  background: rgba(248, 113, 113, 0.05) !important;
  border: 1px solid rgba(248, 113, 113, 0.2) !important;
}

.customer-logout-btn-modern:hover {
  background: linear-gradient(135deg, rgba(248, 113, 113, 0.15), rgba(251, 113, 133, 0.15)) !important;
  color: #ffffff !important;
  transform: translateX(4px) !important;
  box-shadow: 0 6px 20px rgba(248, 113, 113, 0.3) !important;
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.4) !important;
}

.customer-logout-btn-modern .customer-nav-text {
  margin-left: 12px !important;
  font-weight: 500 !important;
}

/* Badge Styles */
.customer-nav-badge {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important;
  color: white !important;
  border-radius: 12px !important;
  padding: 4px 8px !important;
  font-size: 10px !important;
  font-weight: 700 !important;
  margin-left: auto !important;
  min-width: 20px !important;
  height: 20px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3) !important;
  animation: pulse 2s infinite !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}
</style>

<div class="customer-sidebar modern-sidebar" id="customerSidebar">

  <!-- Navigation Menu -->
  <nav class="customer-sidebar-nav">
    <!-- Main Menu Section -->
    <div class="customer-nav-section">
      <div class="customer-nav-section-title">Main Menu</div>
      <ul class="customer-nav-menu">
        <!-- Dashboard -->
        <li class="customer-nav-item">
          <%= link_to customer_root_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_root_path) || current_page?(customer_dashboard_path)}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-green">
                <i class="bi bi-grid-3x3-gap-fill"></i>
              </div>
            </div>
            <span class="customer-nav-text">Dashboard</span>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- Shop -->
        <li class="customer-nav-item">
          <%= link_to customer_shop_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_shop_path) || request.path.include?('/customer/shop')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-emerald">
                <i class="bi bi-shop"></i>
              </div>
            </div>
            <span class="customer-nav-text">Shop</span>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- My Orders -->
        <li class="customer-nav-item">
          <%= link_to customer_orders_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_orders_path) || request.path.include?('/customer/orders')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-teal">
                <i class="bi bi-cart-check-fill"></i>
              </div>
            </div>
            <span class="customer-nav-text">Orders</span>
            <% if current_customer && current_customer.bookings.where(status: ['confirmed', 'processing', 'packed', 'shipped', 'out_for_delivery']).count > 0 %>
              <span class="customer-nav-badge"><%= current_customer.bookings.where(status: ['confirmed', 'processing', 'packed', 'shipped', 'out_for_delivery']).count %></span>
            <% end %>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- My Invoices -->
        <li class="customer-nav-item">
          <%= link_to customer_invoices_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_invoices_path) || request.path.include?('/customer/invoices')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-blue">
                <i class="bi bi-receipt-cutoff"></i>
              </div>
            </div>
            <span class="customer-nav-text">Invoices</span>
            <% if current_customer && current_customer.bookings.where.not(invoice_number: [nil, '']).where(payment_status: [:unpaid, nil]).count > 0 %>
              <span class="customer-nav-badge"><%= current_customer.bookings.where.not(invoice_number: [nil, '']).where(payment_status: [:unpaid, nil]).count %></span>
            <% end %>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- Subscriptions -->
        <li class="customer-nav-item">
          <%= link_to customer_subscriptions_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_subscriptions_path) || request.path.include?('/customer/subscriptions')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-blue">
                <i class="bi bi-arrow-repeat"></i>
              </div>
            </div>
            <span class="customer-nav-text">Subscriptions</span>
            <% if current_customer && current_customer.milk_subscriptions.where(is_active: true).count > 0 %>
              <span class="customer-nav-badge"><%= current_customer.milk_subscriptions.where(is_active: true).count %></span>
            <% end %>
            <div class="nav-indicator"></div>
          <% end %>
        </li>


        <!-- Offers -->
        <li class="customer-nav-item">
          <%= link_to customer_offers_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_offers_path) || request.path.include?('/customer/offers')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-purple">
                <i class="bi bi-tags-fill"></i>
              </div>
            </div>
            <span class="customer-nav-text">Offers</span>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- My Profile -->
        <li class="customer-nav-item">
          <%= link_to customer_profile_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_profile_path) || request.path.include?('/customer/profile')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-orange">
                <i class="bi bi-person-circle"></i>
              </div>
            </div>
            <span class="customer-nav-text">Profile</span>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- Referrals -->
        <li class="customer-nav-item">
          <%= link_to customer_referrals_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_referrals_path) || request.path.include?('/customer/referrals')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-purple">
                <i class="bi bi-share-fill"></i>
              </div>
            </div>
            <span class="customer-nav-text">Refer Friends</span>
            <% if current_customer && current_customer.referrals.pending.count > 0 %>
              <span class="customer-nav-badge"><%= current_customer.referrals.pending.count %></span>
            <% end %>
            <div class="nav-indicator"></div>
          <% end %>
        </li>

        <!-- Support -->
        <li class="customer-nav-item">
          <%= link_to customer_support_path, class: "customer-nav-link-modern #{'active' if current_page?(customer_support_path) || request.path.include?('/customer/support')}" do %>
            <div class="nav-icon-modern">
              <div class="customer-icon-bg customer-gradient-cyan">
                <i class="bi bi-headset"></i>
              </div>
            </div>
            <span class="customer-nav-text">Support</span>
            <% if current_customer && current_customer.client_requests.where(status: ['pending', 'in_progress']).count > 0 %>
              <span class="customer-nav-badge"><%= current_customer.client_requests.where(status: ['pending', 'in_progress']).count %></span>
            <% end %>
            <div class="nav-indicator"></div>
          <% end %>
        </li>
      </ul>
    </div>
  </nav>

  <% if current_customer %>
  <!-- Logout Section -->
  <div class="customer-sidebar-footer">
    <%= button_to customer_logout_path, method: :delete, class: "customer-logout-btn-modern", style: "border: none; background: none; padding: 0; width: 100%;" do %>
      <div class="nav-icon-modern">
        <div class="customer-icon-bg customer-gradient-red">
          <i class="bi bi-box-arrow-right"></i>
        </div>
      </div>
      <span class="customer-nav-text">Logout</span>
    <% end %>
  </div>
  <% end %>
</div>