<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Marali Santhe - Customer Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= javascript_importmap_tags %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Enhanced Bootstrap & Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- jQuery (required for Select2) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <!-- Select2 CSS and JS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <!-- Enhanced Stylesheets -->
    <%= stylesheet_link_tag "sidebar_fallback", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "layout_fix", "data-turbo-track": "reload" %>

    <% if Rails.env.development? %>
      <link rel="stylesheet" href="/application.css" data-turbo-track="reload">
    <% else %>
      <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% end %>

    <!-- ENHANCED CUSTOMER LAYOUT FIXES -->
    <style>
      /* UNIVERSAL LAYOUT RESET AND STANDARDIZATION */
      * {
        box-sizing: border-box;
      }

      body.insurance-app {
        margin: 0;
        padding: 0;
        font-family: 'Poppins', sans-serif;
        background: #f7fafc;
        overflow-x: hidden;
      }

      /* STANDARDIZED HEADER - CONSISTENT ACROSS ALL PAGES */
      html body.insurance-app header.header,
      html body.insurance-app .header,
      html body header.header,
      html body .header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        height: 70px !important;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        border-bottom: 1px solid #e2e8f0 !important;
        z-index: 1050 !important;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
      }

      /* HEADER CONTAINER - STANDARDIZED */
      .header .container-fluid {
        height: 100% !important;
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
        max-width: none !important;
        margin: 0 !important;
        width: 100% !important;
      }

      /* BRAND SECTION - LEFT ALIGNED */
      .header .d-flex.align-items-center.justify-content-start {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-start !important;
        flex-shrink: 0 !important;
        order: 1 !important;
        margin-right: auto !important;
      }

      /* BRAND ICON - CONSISTENT STYLING */
      .header .brand-icon {
        color: #ffffff !important;
        font-size: 1.5rem !important;
        margin-right: 0.75rem !important;
        background: rgba(255, 255, 255, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        width: 42px !important;
        height: 42px !important;
        border-radius: 12px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        flex-shrink: 0 !important;
      }

      /* BRAND TEXT - STANDARDIZED */
      .header .brand-text,
      .header h1.brand-text {
        color: #ffffff !important;
        font-weight: 700 !important;
        font-size: 1.5rem !important;
        margin: 0 !important;
        padding: 0 !important;
        white-space: nowrap !important;
        letter-spacing: -0.5px !important;
        background: none !important;
        -webkit-text-fill-color: #ffffff !important;
      }

      /* HEADER ACTIONS - FORCE RIGHT ALIGNMENT */
      .header .d-flex.align-items-center.gap-3 {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-end !important;
        gap: 1rem !important;
        flex-shrink: 0 !important;
        order: 3 !important;
        margin-left: auto !important;
        padding-right: 0 !important;
      }

      /* STANDARDIZED MAIN CONTENT AREA */
      .main-content {
        margin-left: 260px !important;
        margin-top: 70px !important;
        min-height: calc(100vh - 70px) !important;
        background: #f7fafc !important;
        padding: 0 !important;
        overflow-x: hidden !important;
      }

      /* CONSISTENT CONTAINER FLUID STYLING */
      .main-content .container-fluid {
        max-width: 1400px !important;
        margin: 0 auto !important;
        padding: 2rem !important;
        width: 100% !important;
        box-sizing: border-box !important;
      }

      /* PAGE HEADERS - STANDARDIZED */
      .main-content .d-flex.justify-content-between.align-items-center,
      .main-content .page-header {
        margin-bottom: 2rem !important;
        padding-bottom: 1rem !important;
        border-bottom: 1px solid #e2e8f0 !important;
      }

      .main-content h2 {
        color: #2d3748 !important;
        font-weight: 700 !important;
        font-size: 1.75rem !important;
        margin: 0 !important;
      }

      /* CARD STANDARDIZATION */
      .main-content .card {
        border: 1px solid #e2e8f0 !important;
        border-radius: 16px !important;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
        background: white !important;
        margin-bottom: 1.5rem !important;
      }

      .main-content .card-header {
        background: #f8fafc !important;
        border-bottom: 1px solid #e2e8f0 !important;
        border-radius: 16px 16px 0 0 !important;
        padding: 1.5rem !important;
      }

      .main-content .card-body {
        padding: 1.5rem !important;
      }

      /* RESPONSIVE DESIGN */
      @media (max-width: 768px) {
        .header {
          height: 60px !important;
        }

        .header .brand-text,
        .header h1.brand-text {
          font-size: 1.25rem !important;
        }

        .header .brand-icon {
          width: 36px !important;
          height: 36px !important;
          font-size: 1.25rem !important;
          margin-right: 0.5rem !important;
        }

        .header .container-fluid {
          padding-left: 1rem !important;
          padding-right: 1rem !important;
        }

        .main-content {
          margin-left: 0 !important;
          margin-top: 60px !important;
        }

        .main-content .container-fluid {
          padding: 1rem !important;
        }
      }

      @media (max-width: 480px) {
        .main-content .container-fluid {
          padding: 0.75rem !important;
        }
      }

      /* GRID ALIGNMENT - CONSISTENT ACROSS ALL PAGES */
      .main-content .row {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }

      .main-content .col,
      .main-content [class*="col-"] {
        padding-left: 0.75rem !important;
        padding-right: 0.75rem !important;
      }

      /* BUTTON STANDARDIZATION */
      .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 0.75rem 1.5rem !important;
        font-weight: 500 !important;
        transition: all 0.3s ease !important;
      }

      .btn-primary:hover {
        transform: translateY(-1px) !important;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3) !important;
      }

      /* FORM CONTROLS */
      .form-control,
      .form-select {
        border: 1px solid #e2e8f0 !important;
        border-radius: 8px !important;
        padding: 0.75rem !important;
        font-size: 0.875rem !important;
        transition: all 0.3s ease !important;
      }

      .form-control:focus,
      .form-select:focus {
        border-color: #667eea !important;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1) !important;
      }
    </style>

  </head>

  <body class="insurance-app">
    <% if current_customer %>
      <!-- Enhanced Insurance-themed Header - Same as Admin -->
      <header class="header">
        <div class="container-fluid h-100">
          <div class="d-flex align-items-center justify-content-between h-100" style="padding-left: 1.5rem; padding-right: 1.5rem; width: 100%;">
            <!-- Mobile Toggle -->
            <button class="mobile-toggle d-md-none" type="button" data-bs-toggle="sidebar">
              <i class="fas fa-bars"></i>
            </button>

            <!-- Header Brand -->
            <div class="d-flex align-items-center justify-content-start">
              <div class="brand-icon">
                <i class="fas fa-leaf"></i>
              </div>
              <h1 class="brand-text ms-3 mb-0">Marali Santhe</h1>
            </div>

            <!-- Header Actions -->
            <div class="d-flex align-items-center gap-3">
              <!-- Cart Icon -->
              <div class="position-relative">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="openCartModal()" title="Shopping Cart">
                  <i class="fas fa-shopping-cart me-2"></i>
                  <span class="d-none d-sm-inline">Cart</span>
                </button>
                <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">
                  0
                </span>

                <!-- Cart Modal -->
                <div id="cart-modal" class="cart-modal" style="display: none;">
                  <div class="cart-modal-overlay" onclick="closeCartModal()"></div>
                  <div class="cart-modal-content">
                    <!-- Cart View -->
                    <div id="cart-view" class="cart-view">
                      <div class="cart-header">
                        <h4 class="mb-0">
                          <i class="fas fa-shopping-cart me-2"></i>Shopping Cart
                        </h4>
                        <button class="btn-close" onclick="closeCartModal()"></button>
                      </div>
                      <div class="cart-body">
                        <div id="cart-items-container">
                          <div class="empty-cart-message text-center py-5">
                            <i class="fas fa-shopping-cart text-muted mb-3" style="font-size: 3rem;"></i>
                            <h5 class="text-muted mb-2">Your cart is empty</h5>
                            <p class="text-muted mb-3">Add items to get started!</p>
                            <button class="btn btn-primary" onclick="closeCartModal()">Continue Shopping</button>
                          </div>
                        </div>
                      </div>
                      <div class="cart-footer">
                        <div class="cart-total mb-3">
                          <div class="d-flex justify-content-between">
                            <strong>Total: </strong>
                            <strong id="cart-total">₹0</strong>
                          </div>
                        </div>
                        <div class="d-grid gap-2">
                          <button class="btn btn-primary" onclick="proceedToCheckout()">
                            <i class="fas fa-credit-card me-2"></i>Proceed to Checkout
                          </button>
                          <button class="btn btn-outline-secondary" onclick="closeCartModal()">
                            Continue Shopping
                          </button>
                        </div>
                      </div>
                    </div>

                    <!-- Checkout View -->
                    <div id="checkout-view" class="checkout-view" style="display: none;">
                      <div class="checkout-header">
                        <button class="btn btn-outline-secondary me-2" onclick="backToCart()">
                          <i class="fas fa-arrow-left"></i> Back to Cart
                        </button>
                        <h4 class="mb-0 flex-grow-1">Checkout</h4>
                        <button class="btn-close" onclick="closeCartModal()"></button>
                      </div>
                      <div class="checkout-body">
                        <!-- Address Selection -->
                        <div class="checkout-step" id="address-step">
                          <h5 class="mb-3"><i class="fas fa-map-marker-alt me-2"></i>Delivery Address</h5>
                          <div id="address-list">
                            <!-- Addresses will be loaded here -->
                          </div>
                          <button class="btn btn-outline-primary" onclick="showAddAddressForm()">
                            <i class="fas fa-plus me-2"></i>Add New Address
                          </button>

                          <!-- Add Address Form -->
                          <div id="add-address-form" style="display: none;" class="mt-3">
                            <h6>Add New Address</h6>
                            <form id="new-address-form">
                              <div class="row">
                                <div class="col-md-6">
                                  <input type="text" class="form-control mb-2" name="name" placeholder="Full Name" required>
                                </div>
                                <div class="col-md-6">
                                  <input type="text" class="form-control mb-2" name="mobile" placeholder="Mobile Number" required>
                                </div>
                              </div>
                              <div class="row">
                                <div class="col-md-6">
                                  <select class="form-control mb-2" name="address_type" required>
                                    <option value="">Address Type</option>
                                    <option value="home">Home</option>
                                    <option value="office">Office</option>
                                    <option value="other">Other</option>
                                  </select>
                                </div>
                                <div class="col-md-6">
                                  <input type="text" class="form-control mb-2" name="pincode" placeholder="Pincode" required>
                                </div>
                              </div>
                              <textarea class="form-control mb-2" name="address" placeholder="Address" rows="2" required></textarea>
                              <input type="text" class="form-control mb-2" name="landmark" placeholder="Landmark (Optional)">
                              <div class="row">
                                <div class="col-md-6">
                                  <input type="text" class="form-control mb-2" name="city" placeholder="City" required>
                                </div>
                                <div class="col-md-6">
                                  <input type="text" class="form-control mb-2" name="state" placeholder="State" required>
                                </div>
                              </div>
                              <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Save Address</button>
                                <button type="button" class="btn btn-secondary" onclick="hideAddAddressForm()">Cancel</button>
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Shop Selection for Delivery Only at Shop -->
                        <% if SystemSetting.delivery_only_at_shop_enabled? %>
                        <div class="checkout-step mt-4" id="shop-selection-step">
                          <h5 class="mb-3"><i class="fas fa-store me-2"></i>Select Pickup Location</h5>
                          <div class="alert alert-info mb-3">
                            <i class="fas fa-info-circle me-2"></i>
                            <small>Please select a shop location where you would like to collect your order.</small>
                          </div>
                          <div id="shop-list">
                            <% shop_addresses = SystemSetting.get_shop_addresses %>
                            <% if shop_addresses.any? %>
                              <% shop_addresses.each_with_index do |address, index| %>
                                <div class="form-check shop-option mb-3">
                                  <input class="form-check-input" type="radio" name="delivery_store"
                                         id="shop_<%= index %>" value="<%= address %>" <%= 'checked' if index == 0 %>>
                                  <label class="form-check-label w-100" for="shop_<%= index %>">
                                    <div class="d-flex align-items-start">
                                      <div class="shop-icon me-3">
                                        <i class="fas fa-store text-primary fs-5"></i>
                                      </div>
                                      <div class="flex-grow-1">
                                        <strong class="d-block">Shop <%= index + 1 %></strong>
                                        <small class="text-muted"><%= address %></small>
                                      </div>
                                    </div>
                                  </label>
                                </div>
                              <% end %>
                            <% else %>
                              <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                No pickup locations configured. Please contact support.
                              </div>
                            <% end %>
                          </div>
                        </div>
                        <% end %>

                        <!-- Payment Method -->
                        <div class="checkout-step mt-4" id="payment-step">
                          <h5 class="mb-3"><i class="fas fa-credit-card me-2"></i>Payment Method</h5>
                          <div class="payment-methods">
                            <div class="form-check mb-2">
                              <input class="form-check-input" type="radio" name="payment_method" id="cod" value="cod" checked>
                              <label class="form-check-label" for="cod">
                                <i class="fas fa-money-bill-wave me-2"></i>Cash on Delivery
                              </label>
                            </div>
                            <div class="form-check mb-2">
                              <input class="form-check-input" type="radio" name="payment_method" id="upi" value="upi">
                              <label class="form-check-label" for="upi">
                                <i class="fab fa-google-pay me-2"></i>UPI Payment
                              </label>
                            </div>
                          </div>
                        </div>

                        <!-- Order Summary -->
                        <div class="checkout-step mt-4" id="order-summary">
                          <h5 class="mb-3"><i class="fas fa-list-alt me-2"></i>Order Summary</h5>
                          <div id="checkout-items-summary">
                            <!-- Order items will be displayed here -->
                          </div>
                          <div class="order-total mt-3 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between mb-2">
                              <span>Subtotal:</span>
                              <span id="subtotal-amount">₹0</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                              <span>Delivery:</span>
                              <span class="text-success">Free</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between fw-bold">
                              <span>Total:</span>
                              <span id="final-total">₹0</span>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div class="checkout-footer">
                        <button class="btn btn-success btn-lg w-100" onclick="placeOrder()">
                          <i class="fas fa-check me-2"></i>Place Order
                        </button>
                      </div>
                    </div>

                    <!-- Order Success View -->
                    <div id="success-view" class="success-view" style="display: none;">
                      <div class="success-content text-center py-5">
                        <i class="fas fa-check-circle text-success mb-4" style="font-size: 4rem;"></i>
                        <h3 class="text-success mb-3">Order Placed Successfully!</h3>
                        <p class="text-muted mb-4">Your order has been received and is being processed.</p>
                        <div id="order-details" class="mb-4">
                          <!-- Order details will be shown here -->
                        </div>
                        <div class="d-grid gap-2">
                          <button class="btn btn-primary" onclick="viewOrders()">View My Orders</button>
                          <button class="btn btn-outline-secondary" onclick="continueShopping()">Continue Shopping</button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="dropdown">
                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                  <i class="fas fa-user-circle me-2"></i>
                  <span class="d-none d-sm-inline"><%= current_customer.first_name || 'Customer' %></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to customer_profile_path, class: "dropdown-item" do %>
                    <i class="fas fa-user me-2"></i>My Profile
                  <% end %></li>
                  <li><%= link_to customer_orders_path, class: "dropdown-item" do %>
                    <i class="fas fa-box me-2"></i>My Orders
                  <% end %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to customer_logout_path, method: :delete, class: "dropdown-item" do %>
                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                  <% end %></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- Enhanced Customer Sidebar - Same style as Admin -->
      <%= render 'layouts/customer_sidebar' %>

      <!-- Main Application Layout -->
      <main class="main-content">
        <div class="container-fluid">
          <!-- Flash Messages - Slide-in Toast Notifications -->
          <% if notice %>
            <div id="toast-notification" class="toast-notification toast-success" style="position: fixed; top: 80px; right: 20px; z-index: 9999; width: 350px; background: #d1edda; border: 1px solid #c3e6cb; color: #155724; border-radius: 0.375rem; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15); transform: translateX(100%); transition: transform 0.3s ease-in-out;">
              <div class="toast-notification-content" style="padding: 1rem; display: flex; align-items: center; justify-content: space-between;">
                <div class="d-flex align-items-center">
                  <i class="fas fa-check-circle me-2" style="color: #155724;"></i>
                  <span><%= notice %></span>
                </div>
                <button type="button" class="btn-close ms-3" onclick="closeToast()" style="background: none; border: none; color: #155724; cursor: pointer; font-size: 1.2rem;">&times;</button>
              </div>
            </div>
          <% end %>

          <% if alert %>
            <div id="toast-notification" class="toast-notification toast-danger" style="position: fixed; top: 80px; right: 20px; z-index: 9999; width: 350px; background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 0.375rem; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15); transform: translateX(100%); transition: transform 0.3s ease-in-out;">
              <div class="toast-notification-content" style="padding: 1rem; display: flex; align-items: center; justify-content: space-between;">
                <div class="d-flex align-items-center">
                  <i class="fas fa-exclamation-triangle me-2" style="color: #721c24;"></i>
                  <span><%= alert %></span>
                </div>
                <button type="button" class="btn-close ms-3" onclick="closeToast()" style="background: none; border: none; color: #721c24; cursor: pointer; font-size: 1.2rem;">&times;</button>
              </div>
            </div>
          <% end %>

          <!-- Main Content Area -->
          <div class="content-area">
            <%= yield %>
          </div>

        </div>
      </main>
    <% else %>
      <!-- Authentication Layout -->
      <div class="auth-wrapper">
        <!-- Background pattern overlay -->
        <div class="auth-pattern"></div>

        <!-- Large floating shapes -->
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>

        <% if notice && notice.present? && !notice.include?('http://') && !notice.include?('https://') %>
          <div class="alert alert-success alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 1000; max-width: 90%; width: 400px;">
            <i class="bi bi-check-circle me-2"></i>
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>

        <% if alert && alert.present? && !alert.include?("http://") && !alert.include?("https://") && !request.path.include?("login") %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 1000; max-width: 90%; width: 400px;">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% end %>

        <main class="auth-container">
          <%= yield %>
        </main>
      </div>
    <% end %>

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Cart Dropdown Styles -->
    <style>
      /* Complete Cart Modal System */
      .cart-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1050;
        display: none;
      }

      .cart-modal-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        cursor: pointer;
      }

      .cart-modal-content {
        position: absolute;
        top: 0;
        right: 0;
        width: 100%;
        max-width: 420px;
        height: 100%;
        background: white;
        box-shadow: -10px 0 30px rgba(0, 0, 0, 0.15);
        display: flex;
        flex-direction: column;
        animation: slideInRight 0.3s ease-out;
        border-radius: 15px 0 0 15px;
      }

      @keyframes slideInRight {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
      }

      /* Cart View Styles */
      .cart-header, .checkout-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 1.5rem 1.2rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        color: white;
        border-radius: 15px 0 0 0;
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .cart-header h4, .checkout-header h4 {
        margin: 0;
        font-weight: 600;
        font-size: 1.3rem;
      }

      .cart-body, .checkout-body {
        flex: 1;
        overflow-y: auto;
        padding: 0;
        background: #f8fafc;
        max-height: calc(100vh - 160px);
      }

      .cart-footer, .checkout-footer {
        padding: 1.5rem;
        border-top: 1px solid #e2e8f0;
        background: white;
        position: sticky;
        bottom: 0;
        z-index: 10;
        box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.1);
      }

      .cart-item {
        background: white;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin: 1rem 1.5rem;
        padding: 1rem;
        border: 1px solid #f1f5f9;
      }

      .cart-item:hover {
        box-shadow: 0 4px 20px rgba(16, 185, 129, 0.15);
        transform: translateY(-2px);
        border-color: #10b981;
      }

      .cart-item:last-child {
        margin-bottom: 1rem;
      }

      /* Cart Sections */
      .cart-section {
        background: white;
        margin: 1rem 1.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }

      .cart-section-header {
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        font-weight: 600;
        color: #374151;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .cart-section-content {
        padding: 1.5rem;
      }

      .quantity-controls button {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
      }

      /* Checkout Styles */
      .checkout-step {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .address-card {
        transition: all 0.3s ease;
        cursor: pointer;
      }

      .address-card:hover {
        background: #f8fafc !important;
        border-color: #10b981 !important;
      }

      .address-card.border-primary {
        background: #f0fdf4 !important;
      }

      .payment-methods .form-check {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 1rem;
        transition: all 0.3s ease;
      }

      .payment-methods .form-check:hover {
        background: #f8fafc;
        border-color: #10b981;
      }

      .payment-methods .form-check-input:checked ~ .form-check-label {
        color: #10b981;
        font-weight: 600;
      }

      .order-total {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border: 1px solid #bbf7d0 !important;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1rem;
      }

      /* Enhanced Order Summary Styling */
      .order-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f1f5f9;
      }

      .order-summary-row:last-child {
        border-bottom: none;
        font-weight: 600;
        font-size: 1.1rem;
        color: #059669;
        padding-top: 1rem;
      }

      .order-summary-label {
        color: #6b7280;
        font-weight: 500;
      }

      .order-summary-value {
        color: #374151;
        font-weight: 600;
      }

      /* Payment Method Selector */
      .payment-method-item {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        margin-bottom: 0.75rem;
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
      }

      .payment-method-item:hover {
        border-color: #10b981;
        background: #f0fdf4;
      }

      .payment-method-item.selected {
        border-color: #10b981;
        background: #f0fdf4;
      }

      .payment-method-icon {
        font-size: 1.25rem;
        margin-right: 0.75rem;
        color: #10b981;
      }

      /* Success View */
      .success-view {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
      }

      .order-success-card {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border: 1px solid #bbf7d0 !important;
      }

      /* Form Styles */
      .form-control:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.25);
      }

      /* Button Styles */
      .btn-primary {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
      }

      .btn-primary:hover {
        background: linear-gradient(135deg, #059669, #047857);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
      }

      .btn-success {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border: none;
        font-weight: 600;
      }

      .btn-success:hover {
        background: linear-gradient(135deg, #16a34a, #15803d);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        .cart-modal-content {
          max-width: 100%;
        }

        .cart-header h4, .checkout-header h4 {
          font-size: 1.2rem;
        }

        .cart-item .col-3 {
          flex: 0 0 25%;
        }

        .cart-item .col-6 {
          flex: 0 0 50%;
        }

        .cart-item .col-3:last-child {
          flex: 0 0 25%;
        }
      }

      @media (max-width: 576px) {
        .cart-modal-content {
          width: 100%;
          max-width: 100%;
        }

        .cart-body, .checkout-body, .cart-footer, .checkout-footer {
          padding: 1rem;
        }

        .cart-header, .checkout-header {
          padding: 1rem;
        }

        .checkout-step {
          padding: 1rem;
        }
      }

      /* Enhanced Scrollbar Styles */
      .cart-body::-webkit-scrollbar, .checkout-body::-webkit-scrollbar {
        width: 8px;
      }

      .cart-body::-webkit-scrollbar-track, .checkout-body::-webkit-scrollbar-track {
        background: rgba(241, 245, 249, 0.5);
        border-radius: 4px;
        margin: 10px 0;
      }

      .cart-body::-webkit-scrollbar-thumb, .checkout-body::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 4px;
        border: 2px solid rgba(255, 255, 255, 0.2);
      }

      .cart-body::-webkit-scrollbar-thumb:hover, .checkout-body::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(135deg, #059669, #047857);
      }

      /* Empty Cart State */
      .empty-cart {
        text-align: center;
        padding: 3rem 2rem;
        color: #9ca3af;
      }

      .empty-cart i {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: #d1d5db;
      }

      .empty-cart h5 {
        color: #6b7280;
        margin-bottom: 0.5rem;
      }

      .empty-cart p {
        font-size: 0.9rem;
      }

      /* Checkout Sidebar Scrolling Fix */
      .checkout-sidebar {
        position: sticky;
        top: 20px;
        height: fit-content;
        max-height: calc(100vh - 40px);
        overflow: hidden;
      }

      .checkout-sidebar > div {
        max-height: calc(100vh - 40px);
        overflow-y: auto;
        overflow-x: hidden;
      }

      /* Checkout Items Container Scrolling */
      .checkout-items-container {
        max-height: 300px;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 5px;
        margin-right: -5px;
      }

      /* Custom scrollbar for checkout sidebar */
      .checkout-sidebar > div::-webkit-scrollbar,
      .checkout-items-container::-webkit-scrollbar {
        width: 6px;
      }

      .checkout-sidebar > div::-webkit-scrollbar-track,
      .checkout-items-container::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
      }

      .checkout-sidebar > div::-webkit-scrollbar-thumb,
      .checkout-items-container::-webkit-scrollbar-thumb {
        background: #10b981;
        border-radius: 3px;
      }

      .checkout-sidebar > div::-webkit-scrollbar-thumb:hover,
      .checkout-items-container::-webkit-scrollbar-thumb:hover {
        background: #059669;
      }

      /* Responsive adjustments for checkout sidebar */
      @media (max-width: 992px) {
        .checkout-sidebar {
          position: static;
          max-height: none;
        }

        .checkout-sidebar > div {
          max-height: none;
          overflow-y: visible;
        }

        .checkout-items-container {
          max-height: none;
          overflow-y: visible;
        }
      }
    </style>

    <!-- Enhanced Application Scripts -->
    <script>
      // Aggressively remove all flash messages to prevent any order-related notifications
      document.addEventListener('DOMContentLoaded', function() {
        // Function to remove all flash messages
        function removeAllFlashMessages() {
          const flashMessages = document.querySelectorAll('.alert, .toast, .notification, .flash, [class*="alert"], [class*="notification"], [class*="flash"]');
          flashMessages.forEach(function(alert) {
            if (alert && alert.parentNode) {
              alert.remove();
            }
          });
        }

        // Remove immediately on page load
        removeAllFlashMessages();

        // Set up aggressive periodic removal every 100ms
        setInterval(removeAllFlashMessages, 100);

        // Also remove on any DOM mutations
        const observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.addedNodes.length > 0) {
              setTimeout(removeAllFlashMessages, 10);
            }
          });
        });

        observer.observe(document.body, {
          childList: true,
          subtree: true
        });
      });

      // Chart.js Configuration
      if (typeof Chart !== 'undefined') {
        Chart.defaults.color = '#64748b';
        Chart.defaults.borderColor = 'rgba(100, 116, 139, 0.1)';
        Chart.defaults.backgroundColor = 'rgba(59, 130, 246, 0.1)';
      }

      // Animation utility
      function animateValue(element, start, end, duration) {
        let startTimestamp = null;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          element.textContent = Math.floor(progress * (end - start) + start).toLocaleString();
          if (progress < 1) {
            window.requestAnimationFrame(step);
          }
        };
        window.requestAnimationFrame(step);
      }

      // Initialize animations on page load
      function initializeAnimations() {
        document.querySelectorAll('[data-animate-value]').forEach(element => {
          const value = parseInt(element.textContent.replace(/,/g, ''));
          if (!isNaN(value)) {
            animateValue(element, 0, value, 1500);
          }
        });
      }

      // Initialize mobile sidebar toggle
      function initializeMobileSidebar() {
        const toggleButton = document.querySelector('[data-bs-toggle="sidebar"]');
        const sidebar = document.querySelector('.modern-sidebar');

        if (toggleButton && sidebar) {
          toggleButton.addEventListener('click', function() {
            sidebar.classList.toggle('sidebar-open');
            document.body.classList.toggle('sidebar-open');
          });

          // Close sidebar when clicking outside on mobile
          document.addEventListener('click', function(e) {
            if (window.innerWidth < 992 &&
                !sidebar.contains(e.target) &&
                !toggleButton.contains(e.target) &&
                sidebar.classList.contains('sidebar-open')) {
              sidebar.classList.remove('sidebar-open');
              document.body.classList.remove('sidebar-open');
            }
          });
        }
      }

      // Initialize Select2 dropdowns
      function initializeSelect2() {
        if (typeof $.fn.select2 !== 'undefined') {
          $('.select2').select2({
            theme: 'bootstrap-5',
            placeholder: function() {
              return $(this).data('placeholder');
            }
          });
        }
      }

      // Toast Notifications
      function showToast(message, type = 'success') {
        // Map 'error' to 'danger' for Bootstrap
        const bootstrapType = type === 'error' ? 'danger' : type;
        const icon = type === 'success' ? 'check-circle' : 'exclamation-triangle';

        const toastHtml = `
          <div class="toast align-items-center text-white bg-${bootstrapType} border-0" role="alert" style="position: fixed; top: 90px; right: 20px; z-index: 9999;">
            <div class="d-flex">
              <div class="toast-body">
                <i class="fas fa-${icon} me-2"></i>
                ${message}
              </div>
              <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
          </div>
        `;
        document.body.insertAdjacentHTML('beforeend', toastHtml);
        const toast = new bootstrap.Toast(document.querySelector('.toast:last-child'));
        toast.show();
      }

      // Toast notification functions
      function initToastNotifications() {
        const toast = document.getElementById('toast-notification');
        if (toast) {
          setTimeout(function() {
            toast.style.transform = 'translateX(0)';
          }, 100);
          setTimeout(function() {
            closeToast();
          }, 5000);
        }
      }

      function closeToast() {
        const toast = document.getElementById('toast-notification');
        if (toast) {
          toast.style.transform = 'translateX(100%)';
          setTimeout(function() {
            if (toast.parentNode) {
              toast.parentNode.removeChild(toast);
            }
          }, 300);
        }
      }

      // Cart functionality
      function updateCartBadge() {
        const cartItems = JSON.parse(localStorage.getItem('customerCart') || '[]');
        const badge = document.getElementById('cart-badge');
        const totalItems = cartItems.reduce((total, item) => total + (parseFloat(item.quantity) || 0), 0);

        if (badge && totalItems > 0) {
          badge.textContent = totalItems > 99 ? '99+' : Math.round(totalItems);
          badge.style.display = 'block';
        } else if (badge) {
          badge.style.display = 'none';
        }

        // Update cart modal if it's open
        if (cartModalOpen) {
          loadCartData();
        }
      }

      // Complete Frontend Cart & Checkout System
      let cartModalOpen = false;
      let currentView = 'cart'; // cart, checkout, success
      let selectedAddress = null;
      let customerAddresses = [];

      // Cart Modal Functions
      function openCartModal() {
        const modal = document.getElementById('cart-modal');
        showCartView();
        loadCartData();
        modal.style.display = 'block';
        document.body.style.overflow = 'hidden';
        cartModalOpen = true;
      }

      function closeCartModal() {
        const modal = document.getElementById('cart-modal');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
        cartModalOpen = false;
        currentView = 'cart';
      }

      function showCartView() {
        document.getElementById('cart-view').style.display = 'block';
        document.getElementById('checkout-view').style.display = 'none';
        document.getElementById('success-view').style.display = 'none';
        currentView = 'cart';
      }

      function showCheckoutView() {
        document.getElementById('cart-view').style.display = 'none';
        document.getElementById('checkout-view').style.display = 'block';
        document.getElementById('success-view').style.display = 'none';
        currentView = 'checkout';
        loadAddresses();
        loadCheckoutSummary();
      }

      function showSuccessView() {
        document.getElementById('cart-view').style.display = 'none';
        document.getElementById('checkout-view').style.display = 'none';
        document.getElementById('success-view').style.display = 'block';
        currentView = 'success';
      }

      function backToCart() {
        showCartView();
        loadCartData();
      }

      function proceedToCheckout() {
        const cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        if (cart.length === 0) {
          alert('Your cart is empty');
          return;
        }
        showCheckoutView();
      }

      // Cart Data Functions
      function loadCartData() {
        const cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        const container = document.getElementById('cart-items-container');
        const totalElement = document.getElementById('cart-total');

        if (cart.length === 0) {
          container.innerHTML = `
            <div class="empty-cart-message text-center py-5">
              <i class="fas fa-shopping-cart text-muted mb-3" style="font-size: 3rem;"></i>
              <h5 class="text-muted mb-2">Your cart is empty</h5>
              <p class="text-muted mb-3">Add items to get started!</p>
              <button class="btn btn-primary" onclick="closeCartModal()">Continue Shopping</button>
            </div>
          `;
          totalElement.textContent = '₹0';
          return;
        }

        let total = 0;
        let itemsHtml = '';

        cart.forEach((item, index) => {
          const itemTotal = (item.price || 0) * (item.quantity || 0);
          total += itemTotal;

          itemsHtml += `
            <div class="cart-item mb-3 p-3 border rounded">
              <div class="row align-items-center">
                <div class="col-3">
                  <div class="cart-item-image bg-light d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 8px;">
                    <i class="fas fa-image text-muted" style="font-size: 2rem;"></i>
                  </div>
                </div>
                <div class="col-6">
                  <h6 class="cart-item-name mb-1">${item.name || 'Product'}</h6>
                  <p class="text-muted mb-2">₹${(item.price || 0).toFixed(2)} each</p>
                  <div class="quantity-controls d-flex align-items-center">
                    <button class="btn btn-sm btn-outline-secondary" onclick="updateCartQuantity(${item.id}, ${item.quantity - 1})">-</button>
                    <span class="mx-3">${item.quantity}</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="updateCartQuantity(${item.id}, ${item.quantity + 1})">+</button>
                  </div>
                </div>
                <div class="col-3 text-end">
                  <h6 class="mb-2">₹${(itemTotal || 0).toFixed(2)}</h6>
                  <button class="btn btn-sm btn-outline-danger" onclick="removeFromCart(${item.id})">
                    <i class="fas fa-trash"></i> Remove
                  </button>
                </div>
              </div>
            </div>
          `;
        });

        container.innerHTML = itemsHtml;
        totalElement.textContent = `₹${(total || 0).toFixed(2)}`;
      }

      function updateCartQuantity(productId, newQuantity) {
        if (newQuantity <= 0) {
          removeFromCart(productId);
          return;
        }

        let cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        const itemIndex = cart.findIndex(item => item.id == productId);

        if (itemIndex > -1) {
          cart[itemIndex].quantity = newQuantity;
          localStorage.setItem('customerCart', JSON.stringify(cart));
          loadCartData();
          updateCartBadge();

          if (currentView === 'checkout') {
            loadCheckoutSummary();
          }
        }
      }

      function removeFromCart(productId) {
        let cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        cart = cart.filter(item => item.id != productId);
        localStorage.setItem('customerCart', JSON.stringify(cart));

        loadCartData();
        updateCartBadge();

        if (currentView === 'checkout') {
          loadCheckoutSummary();
        }

        alert('Item removed from cart');
      }

      // Address Management
      function loadAddresses() {
        // Simulate loading customer addresses (replace with actual API call)
        const addressContainer = document.getElementById('address-list');

        // Mock addresses for now
        customerAddresses = [
          {
            id: 1,
            name: '<%= current_customer&.display_name || "Guest User" %>',
            mobile: '<%= current_customer&.mobile || "N/A" %>',
            address: 'Sample Address, Street 1',
            city: 'City Name',
            state: 'State Name',
            pincode: '123456',
            address_type: 'home',
            is_default: true
          }
        ];

        if (customerAddresses.length === 0) {
          addressContainer.innerHTML = '<p class="text-muted">No saved addresses. Please add a new address.</p>';
          return;
        }

        let addressesHtml = '';
        customerAddresses.forEach((address, index) => {
          const isSelected = selectedAddress?.id === address.id || (index === 0 && !selectedAddress);
          if (index === 0 && !selectedAddress) selectedAddress = address;

          addressesHtml += `
            <div class="address-card mb-3 p-3 border rounded ${isSelected ? 'border-primary bg-light' : ''}">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="selected_address" value="${address.id}"
                       ${isSelected ? 'checked' : ''} onchange="selectAddress(${address.id})">
                <label class="form-check-label">
                  <strong>${address.name}</strong> <span class="badge bg-secondary">${address.address_type}</span>
                  <br>
                  ${address.address}, ${address.city}, ${address.state} - ${address.pincode}
                  <br>
                  <small class="text-muted">📞 ${address.mobile}</small>
                </label>
              </div>
            </div>
          `;
        });

        addressContainer.innerHTML = addressesHtml;
      }

      function selectAddress(addressId) {
        selectedAddress = customerAddresses.find(addr => addr.id == addressId);
      }

      function showAddAddressForm() {
        document.getElementById('add-address-form').style.display = 'block';
      }

      function hideAddAddressForm() {
        document.getElementById('add-address-form').style.display = 'none';
      }

      // Checkout Functions
      function loadCheckoutSummary() {
        const cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        const summaryContainer = document.getElementById('checkout-items-summary');

        let total = 0;
        let itemsHtml = '';

        cart.forEach(item => {
          const itemTotal = (item.price || 0) * (item.quantity || 0);
          total += itemTotal;

          itemsHtml += `
            <div class="checkout-item d-flex justify-content-between align-items-center mb-2">
              <div>
                <span class="fw-medium">${item.name}</span>
                <small class="text-muted"> × ${item.quantity}</small>
              </div>
              <span>₹${(itemTotal || 0).toFixed(2)}</span>
            </div>
          `;
        });

        summaryContainer.innerHTML = itemsHtml;
        document.getElementById('subtotal-amount').textContent = `₹${(total || 0).toFixed(2)}`;
        document.getElementById('final-total').textContent = `₹${(total || 0).toFixed(2)}`;
      }

      function placeOrder() {
        if (!selectedAddress) {
          alert('Please select a delivery address');
          return;
        }

        const cart = JSON.parse(localStorage.getItem('customerCart') || '[]');
        if (cart.length === 0) {
          alert('Your cart is empty');
          return;
        }

        // Check for delivery store selection if delivery only at shop is enabled
        <% if SystemSetting.delivery_only_at_shop_enabled? %>
        const selectedDeliveryStore = document.querySelector('input[name="delivery_store"]:checked');
        if (!selectedDeliveryStore) {
          alert('Please select a pickup location');
          return;
        }
        <% end %>

        const paymentMethod = document.querySelector('input[name="payment_method"]:checked').value;

        // Create order data for backend
        const orderData = {
          customer_name: selectedAddress.name,
          customer_phone: selectedAddress.mobile,
          customer_email: '<%= current_customer&.email %>',
          delivery_address: `${selectedAddress.address}, ${selectedAddress.city}, ${selectedAddress.state} - ${selectedAddress.pincode}`,
          payment_method: paymentMethod,
          payment_status: paymentMethod === 'cod' ? 'unpaid' : 'paid',
          cart_data: cart
        };

        // Add delivery store if selected
        <% if SystemSetting.delivery_only_at_shop_enabled? %>
        if (selectedDeliveryStore) {
          orderData.delivery_store = selectedDeliveryStore.value;
        }
        <% end %>

        // Show loading
        const placeOrderBtn = event.target;
        placeOrderBtn.disabled = true;
        placeOrderBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Placing Order...';

        // Make API call to place order
        fetch('/customer/checkout/cart_order', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
          },
          body: JSON.stringify(orderData)
        })
        .then(response => {
          console.log('Response status:', response.status);
          console.log('Response headers:', response.headers.get('content-type'));
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          // Ensure we're getting JSON response
          const contentType = response.headers.get('content-type');
          if (!contentType || !contentType.includes('application/json')) {
            throw new Error('Invalid response format - expected JSON');
          }

          return response.json();
        })
        .then(data => {
          console.log('Order response data:', data);
          if (data && data.success) {
            // Clear cart first
            localStorage.removeItem('customerCart');
            updateCartBadge();

            // Hide all modal views to prevent any UI conflicts
            document.getElementById('cart-view').style.display = 'none';
            document.getElementById('checkout-view').style.display = 'none';
            document.getElementById('success-view').style.display = 'none';

            // Clear any existing flash messages and toasts first
            const existingAlerts = document.querySelectorAll('.alert, .toast, .alert-success, .alert-danger, .alert-warning');
            existingAlerts.forEach(el => el.remove());

            // Convert total_amount to number and format properly
            const totalAmount = parseFloat(data.total_amount || 0).toFixed(2);

            // Show success alert with order details
            alert(`🎉 Order Placed Successfully!\\n\\nOrder Number: ${data.booking_number}\\nTotal Amount: ₹${totalAmount}\\nPayment: ${paymentMethod.toUpperCase()}\\n\\nRedirecting to your order details...`);

            // Additional cleanup: Remove any remaining alerts before redirect
            setTimeout(() => {
              document.querySelectorAll('.alert').forEach(el => el.remove());
            }, 100);

            // Redirect to specific order details page
            window.location.href = `/customer/orders/${data.booking_id}`;

            return; // Exit early on success
          } else {
            throw new Error(data?.error || 'Failed to place order');
          }
        })
        .catch(error => {
          console.error('Error placing order:', error);

          // Only show error if we haven't already redirected
          if (!document.hidden) {
            alert('Failed to place order. Please try again.');

            // Reset button on error only
            placeOrderBtn.disabled = false;
            placeOrderBtn.innerHTML = '<i class="fas fa-check me-2"></i>Place Order';
          }
        });
      }

      // Success View Functions
      function viewOrders() {
        window.location.href = '<%= customer_orders_path %>';
      }

      function continueShopping() {
        closeCartModal();
        window.location.href = '<%= customer_shop_path %>';
      }

      // Initialize everything when DOM is ready
      document.addEventListener('DOMContentLoaded', function() {
        initializeAnimations();
        initializeMobileSidebar();
        initializeSelect2();
        initToastNotifications();
        updateCartBadge();
      });

      // Initialize on Turbo load as well
      document.addEventListener('turbo:load', function() {
        initializeAnimations();
        initializeMobileSidebar();
        initializeSelect2();
        initToastNotifications();
        updateCartBadge();
      });

      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
          closeToast();
          if (cartModalOpen) {
            closeCartModal();
          }
        }
      });

      // Listen for storage changes (when cart is updated on same page)
      window.addEventListener('storage', updateCartBadge);

      // Listen for custom cart update events
      window.addEventListener('cartUpdated', updateCartBadge);
    </script>

  </body>
</html>