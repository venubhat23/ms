<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Invoice #<%= @invoice.invoice_number %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        background-color: white;
        font-size: 12px;
      }

      .invoice-wrapper {
        max-width: 210mm;
        margin: 0 auto;
        background-color: white;
      }

      .invoice-container {
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto;
        background-color: white;
        padding: 20mm;
        box-sizing: border-box;
        page-break-after: always;
      }

      /* Header section */
      .invoice-header-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 8px;
      }

      .invoice-header-table td {
        vertical-align: top;
        padding: 0;
      }

      .logo-cell {
        width: 150px;
        padding-right: 12px;
      }

      .logo {
        width: 100px;
        height: auto;
        border-radius: 50%;
        border: 3px solid #5a4ec9;
      }

      .company-info-cell {
        width: auto;
      }

      .tax-label-container {
        margin-bottom: 10px;
        position: relative;
      }

      .tax-label {
        font-weight: bold;
        font-size: 14px;
        color: #333;
        display: inline-block;
      }

      .original-recipient {
        display: inline-block;
        font-size: 10px;
        color: #666;
        border: 1px solid #999;
        padding: 2px 6px;
        border-radius: 4px;
        margin-left: 12px;
        background-color: #f9f9f9;
      }

      .company-name {
        color: #5a4ec9;
        font-size: 22px;
        font-weight: bold;
        margin: 0 0 5px 0;
      }

      .address,
      .contact {
        font-size: 11px;
        line-height: 1.3;
        color: #333;
      }

      .highlight {
        font-weight: bold;
      }

      .top-bar {
        height: 6px;
        background-color: #5a4ec9;
        margin-bottom: 10px;
        width: 100%;
      }

      /* Add horizontal line before invoice meta */
      .invoice-divider {
        height: 2px;
        background-color: #5a4ec9;
        margin: 12px 0;
        width: 100%;
        border-radius: 2px;
      }

      /* Invoice meta */
      .invoice-meta-table {
        width: 100%;
        background-color: #e7e7e7;
        border-collapse: collapse;
        margin-bottom: 10px;
        border-radius: 5px;
        overflow: hidden;
      }

      .invoice-meta-table td {
        padding: 8px;
        text-align: center;
        font-size: 12px;
        font-weight: bold;
        width: 33.33%;
        border-right: 1px solid #ddd;
      }

      .invoice-meta-table td:last-child {
        border-right: none;
      }

      .invoice-meta-table span {
        font-weight: normal;
        margin-left: 5px;
      }

      /* Bill/Ship section */
      .bill-ship-table {
        width: 100%;
        border-collapse: collapse;
        margin: 12px 0 10px 0;
      }

      .bill-ship-table td {
        width: 50%;
        vertical-align: top;
        padding: 0 8px;
      }

      .bill-title,
      .ship-title {
        font-size: 12px;
        margin-bottom: 5px;
        font-weight: bold;
        color: #5a4ec9;
      }

      .client-name {
        font-size: 13px;
        font-weight: bold;
        margin-bottom: 3px;
        color: #333;
      }

      .mobile {
        font-size: 11px;
        color: #666;
      }

      /* Items table */
      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
      }

      .items-table thead {
        border-top: 3px solid #5a4ec9;
        border-bottom: 3px solid #5a4ec9;
        background-color: #f8f9fa;
      }

      .items-table th {
        padding: 6px 4px;
        font-size: 12px;
        font-weight: bold;
        text-align: left;
        color: #333;
      }

      .items-table th.center-align {
        text-align: center;
      }

      .items-table th.right-align {
        text-align: right;
      }

      .items-table td {
        padding: 5px 4px;
        font-size: 11px;
        vertical-align: top;
        border-bottom: 1px solid #eee;
      }

      .items-table td.center-align {
        text-align: center;
      }

      .items-table td.right-align {
        text-align: right;
        font-weight: bold;
      }

      .items-table tbody tr:nth-child(even) {
        background-color: #f8f9fa;
      }

      .description {
        color: #666;
        font-size: 10px;
        font-style: italic;
      }

      .tax-rate {
        font-size: 9px;
        color: #888;
      }

      /* Subtotal section */
      .subtotal-table {
        width: 100%;
        border-collapse: collapse;
        margin: 10px 0;
      }

      .subtotal-table .section-border {
        border-top: 3px solid #5a4ec9;
        border-bottom: 3px solid #5a4ec9;
        font-weight: bold;
        font-size: 14px;
        background-color: #f8f9fa;
      }

      .subtotal-table td {
        padding: 8px;
      }

      .subtotal-values-table {
        width: 100%;
        border-collapse: collapse;
      }

      .subtotal-values-table td {
        text-align: right;
        padding: 0 12px;
      }

      .subtotal-cell {
        width: 65%;
        vertical-align: top;
        padding-left: 0;
      }

      .payment-cell {
        width: 35%;
        vertical-align: top;
        padding-left: 12px;
        border-left: 1px solid #ddd;
      }

      .bank-details-container {
        margin: 0;
      }

      .bank-details {
        font-size: 12px;
        margin-bottom: 10px;
      }

      .bank-details-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 8px;
      }

      .bank-details-table td {
        font-size: 10px;
        padding: 2px 0;
        text-align: left;
      }

      .bank-details-table td:first-child {
        font-weight: bold;
        width: 30%;
      }

      .payment-qr-table {
        width: 100%;
        border-collapse: collapse;
        text-align: center;
      }

      .upi-id {
        font-size: 10px;
        margin: 0 0 5px 0;
        font-weight: bold;
        color: #333;
      }

      .upi-icons {
        font-size: 8px;
        display: flex;
        justify-content: center;
        gap: 5px;
        margin-bottom: 5px;
      }

      .upi-icons span {
        padding: 2px 4px;
        border-radius: 3px;
        font-weight: bold;
      }

      .phonepe {
        background-color: #5f259f;
        color: white;
      }

      .gpay {
        background-color: #4285f4;
        color: white;
      }

      .qr-image {
        width: 80px;
        height: 80px;
        border: 1px solid #ddd;
      }

      .tax-line {
        display: flex;
        justify-content: space-between;
        padding: 3px 0;
        font-size: 11px;
      }

      .tax-label {
        font-weight: bold;
      }

      .tax-amount {
        font-weight: bold;
      }

      .total {
        border-top: 2px solid #333;
        border-bottom: 2px solid #333;
        margin: 5px 0;
        font-size: 12px;
        background-color: #f8f9fa;
      }

      .total .tax-line {
        padding: 8px 0;
        font-weight: bold;
      }

      .amount-words {
        margin: 10px 0;
        padding: 8px;
        background-color: #f8f9fa;
        border-radius: 4px;
      }

      .amount-words h3 {
        margin: 0 0 5px 0;
        font-size: 11px;
        color: #333;
      }

      .amount-words p {
        margin: 0;
        font-size: 10px;
        font-weight: bold;
        color: #333;
      }

      /* Footer */
      .footer-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }

      .footer-table td {
        vertical-align: top;
        padding: 10px;
        border-top: 1px solid #ddd;
      }

      .terms-cell {
        width: 60%;
      }

      .signature-cell {
        width: 40%;
        text-align: center;
        border-left: 1px solid #ddd;
      }

      .terms {
        font-size: 10px;
      }

      .terms h3 {
        margin: 0 0 8px 0;
        font-size: 11px;
        color: #5a4ec9;
      }

      .terms ol {
        margin: 0;
        padding-left: 15px;
        line-height: 1.4;
      }

      .terms li {
        margin-bottom: 3px;
      }

      .signature-box {
        width: 120px;
        height: 60px;
        border: 1px solid #333;
        margin: 0 auto 8px;
        border-radius: 4px;
      }

      .signature-label {
        font-size: 9px;
        color: #666;
        margin-bottom: 3px;
      }

      .signature-name {
        font-size: 10px;
        font-weight: bold;
        color: #333;
      }

      /* Responsive adjustments for PDF */
      @media print {
        body {
          background-color: white;
        }
        .invoice-wrapper {
          box-shadow: none;
          margin: 0;
        }
      }
    </style>
  </head>
  <body>
    <%
      # Get invoice items with booking expansion for detailed view
      invoice_items = []
      if @invoice.respond_to?(:invoice_items) && @invoice.invoice_items.any?
        @invoice.invoice_items.each do |item|
          # Check if this is a booking summary item
          if item.description&.include?('Booking #') && !item.product_id.present?
            # Extract booking number and get individual items
            booking_match = item.description.match(/#(BK[A-Z0-9]+)/)
            if booking_match
              booking_number = booking_match[1]
              booking = Booking.find_by(booking_number: booking_number)

              if booking&.booking_items&.any?
                # Add individual booking items instead of summary
                booking.booking_items.includes(:product).each do |booking_item|
                  invoice_items << OpenStruct.new(
                    description: booking_item.product&.name || 'Product',
                    quantity: booking_item.quantity || 1,
                    unit_price: booking_item.price || 0,
                    product: booking_item.product
                  )
                end
              else
                # Fallback to original item if booking not found
                invoice_items << item
              end
            else
              # Not a booking item, add as is
              invoice_items << item
            end
          else
            # Regular item, add as is
            invoice_items << item
          end
        end
      elsif @invoice.respond_to?(:booking) && @invoice.booking&.order&.order_items&.any?
        # For booking invoices, try to get items from order
        invoice_items = @invoice.booking.order.order_items.map do |order_item|
          # Create a struct to mimic invoice_item interface
          OpenStruct.new(
            description: order_item.product&.name || 'Product',
            quantity: order_item.quantity || 1,
            unit_price: order_item.unit_price || 0,
            product: order_item.product
          )
        end
      end

      # Calculate if any product has GST
      has_gst = invoice_items.any? { |item| item.product&.gst_enabled }

      # Calculate totals with proper GST breakdown (same logic as HTML template)
      subtotal_amount = 0
      taxable_amount = 0
      total_cgst = 0
      total_sgst = 0
      total_igst = 0

      invoice_items.each do |item|
        # Base amount (quantity × unit_price) - rounded to 2 decimal places
        base_amount = (item.quantity * (item.unit_price || 0)).round(2)

        # Add to subtotal
        subtotal_amount += base_amount

        if item.product&.gst_enabled
          # For GST applicable items, add to taxable amount and calculate GST
          taxable_amount += base_amount

          # Calculate individual tax components based on base amount
          cgst_rate = item.product.cgst_percentage || 0
          sgst_rate = item.product.sgst_percentage || 0
          igst_rate = item.product.igst_percentage || 0

          # If individual rates are not set, use main gst_percentage split evenly between CGST and SGST
          if cgst_rate == 0 && sgst_rate == 0 && igst_rate == 0 && item.product.gst_percentage.present?
            main_gst_rate = item.product.gst_percentage
            cgst_rate = main_gst_rate / 2
            sgst_rate = main_gst_rate / 2
          end

          cgst_amount = (base_amount * cgst_rate / 100).round(2)
          sgst_amount = (base_amount * sgst_rate / 100).round(2)
          igst_amount = (base_amount * igst_rate / 100).round(2)

          total_cgst += cgst_amount
          total_sgst += sgst_amount
          total_igst += igst_amount
        end
      end

      total_tax = total_cgst + total_sgst + total_igst
      discount_amount = @invoice.respond_to?(:discount_amount) ? (@invoice.discount_amount || 0) : 0
      final_total = subtotal_amount + total_tax - discount_amount
    %>

    <%
      # Get business settings (same as HTML template)
      business_settings = @business_settings || SystemSetting.business_settings
    %>

    <!-- Invoice Wrapper for A4 Format -->
    <div class="invoice-wrapper">
      <div class="invoice-container">
        <!-- Tax label and original recipient -->
        <div class="tax-label-container">
          <span class="tax-label"><%= has_gst ? 'TAX INVOICE' : 'BILL OF SUPPLY' %></span>
          <span class="original-recipient">ORIGINAL FOR RECIPIENT</span>
        </div>

        <!-- Company header -->
        <table class="invoice-header-table">
          <tr>
            <td class="logo-cell">
              <img class="logo" src="/logo.jpeg" alt="Marali Santhe Logo" />
            </td>
            <td class="company-info-cell">
              <div class="company-name"><%= business_settings&.business_name || 'Marali Santhe' %></div>
              <div class="address">
                <%= business_settings&.address || '#827 4th main 9th Block 2nd Stage Near Hanumagiri temple Nagarbhavi, Bangalore, Karnataka, 560072' %>
              </div>
              <div class="contact">
                <span class="highlight">Mobile:</span> <%= business_settings&.mobile || '9972808044' %> &nbsp;&nbsp;
                <span class="highlight">GSTIN:</span> <%= business_settings&.gstin || '29AOIPT8113K1ZC' %> &nbsp;&nbsp;
                <span class="highlight">PAN Number:</span> <%= business_settings&.pan_number || 'AOIPT8113K' %><br />
                <span class="highlight">Email:</span> <%= business_settings&.email || 'Marali Santhefarm@gmail.com' %>
              </div>
            </td>
          </tr>
        </table>

        <div class="top-bar"></div>
        <div class="invoice-divider"></div>

        <!-- Invoice meta data -->
        <table class="invoice-meta-table">
          <tr>
            <td>Invoice No:<span><%= @invoice.invoice_number %></span></td>
            <td>Invoice Date:<span><%= @invoice.invoice_date&.strftime('%d/%m/%Y') || Date.current.strftime('%d/%m/%Y') %></span></td>
            <td>Due Date:<span><%= @invoice.due_date&.strftime('%d/%m/%Y') || (Date.current + 30.days).strftime('%d/%m/%Y') %></span></td>
          </tr>
        </table>

        <!-- Bill to / Ship to -->
        <table class="bill-ship-table">
          <tr>
            <td>
              <div class="bill-title">BILL TO</div>
              <div class="client-name"><%= @customer&.display_name || 'Customer Name' %></div>
              <div><%= @customer&.address || 'Address' %></div>
              <% if @customer&.mobile.present? %>
                <div class="mobile">Mobile: <%= @customer.mobile %></div>
              <% end %>
            </td>
            <td>
              <div class="ship-title">SHIP TO</div>
              <div class="client-name"><%= @customer&.display_name || 'Customer Name' %></div>
              <div><%= @customer&.address || 'Address' %></div>
            </td>
          </tr>
        </table>

        <!-- Items table -->
        <table class="items-table">
          <thead>
            <tr>
              <th>DESCRIPTION</th>
              <th class="center-align">HSN/SAC</th>
              <th class="center-align">QTY</th>
              <th class="right-align">RATE</th>
              <th class="right-align">TAX</th>
              <th class="right-align">AMOUNT</th>
            </tr>
          </thead>
          <tbody>
            <% if invoice_items.any? %>
              <% invoice_items.each do |item| %>
                <tr>
                  <td>
                    <div>
                      <%
                        # Show product name if available, otherwise show description
                        if item.product&.name.present?
                          product_name = item.product.name
                        else
                          # For items without products (like booking summaries), use description
                          product_name = item.description.present? ? item.description : 'Product'
                        end
                      %>
                      <%= product_name %>
                      <% if item.description.present? && item.description != product_name && item.product&.name.present? %>
                        <br><span class="description"><%= item.description %></span>
                      <% end %>
                    </div>
                  </td>
                  <td class="center-align"><%= item.product&.hsn_code || '-' %></td>
                  <td class="center-align"><%= item.quantity %> <%= item.product&.unit_type || 'PCS' %></td>
                  <td class="right-align">
                    <%
                      # Display base unit price (without GST) - same logic as HTML template
                      unit_price = item.unit_price || 0
                    %>
                    ₹<%= number_with_delimiter(sprintf('%.2f', unit_price), delimiter: ',') %>
                  </td>
                  <td class="right-align">
                    <%
                      base_amount = item.quantity * (item.unit_price || 0)
                      if item.product&.gst_enabled
                        # Get total GST rate - prioritize combined CGST+SGST+IGST, fallback to main gst_percentage
                        total_gst_rate = (item.product.cgst_percentage || 0) + (item.product.sgst_percentage || 0) + (item.product.igst_percentage || 0)
                        total_gst_rate = item.product.gst_percentage || 0 if total_gst_rate == 0
                        tax_amount = (base_amount * total_gst_rate) / 100
                      else
                        total_gst_rate = 0
                        tax_amount = 0
                      end
                    %>
                    ₹<%= number_with_delimiter(tax_amount.round(2), delimiter: ',') %><br />
                    <span class="tax-rate">(<%= total_gst_rate.to_i == total_gst_rate ? total_gst_rate.to_i : total_gst_rate %>%)</span>
                  </td>
                  <td class="right-align">
                    <%
                      # The item.unit_price already includes GST, so this is the gross amount
                      gross_amount = item.quantity * (item.unit_price || 0)

                      # Apply proportional discount directly to the gross amount
                      if discount_amount > 0 && invoice_items.length > 0
                        # For single item invoices, apply full discount. For multiple items, apply proportionally
                        total_gross = invoice_items.sum { |i| i.quantity * (i.unit_price || 0) }
                        item_proportion = gross_amount / total_gross
                        item_discount = discount_amount * item_proportion
                        final_amount = gross_amount - item_discount
                      else
                        final_amount = gross_amount
                      end
                    %>
                    ₹<%= number_with_delimiter(final_amount.round(2), delimiter: ',') %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td>Invoice Total</td>
                <td class="center-align">-</td>
                <td class="center-align">1</td>
                <td class="right-align">₹<%= number_with_delimiter(@invoice.total_amount || 0, delimiter: ',') %></td>
                <td class="right-align">₹0<br /><span class="tax-rate">(0%)</span></td>
                <td class="right-align">₹<%= number_with_delimiter(@invoice.total_amount || 0, delimiter: ',') %></td>
              </tr>
              <% subtotal_amount = @invoice.total_amount || 0 %>
            <% end %>
          </tbody>
        </table>

        <!-- Subtotal section -->
        <table class="subtotal-table">
          <tr class="section-border">
            <td class="subtotal-cell">Bank Details & Payment Methods</td>
            <td class="payment-cell">Summary</td>
          </tr>
          <tr>
            <td class="subtotal-cell">
              <div class="bank-details-container">
                <div class="bank-details">Payment Details</div>
                <table class="bank-details-table">
                  <tr>
                    <td>Name:</td>
                    <td><%= business_settings&.account_holder_name || 'Marali Santhe' %></td>
                  </tr>
                  <tr>
                    <td>IFSC Code:</td>
                    <td><%= business_settings&.ifsc_code || 'CNRB0003194' %></td>
                  </tr>
                  <tr>
                    <td>Account No:</td>
                    <td><%= business_settings&.account_number || '3194201000718' %></td>
                  </tr>
                  <tr>
                    <td>Bank:</td>
                    <td><%= business_settings&.bank_name || 'Canara Bank' %></td>
                  </tr>
                </table>

                <table class="payment-qr-table">
                  <tr>
                    <td>
                      <p class="upi-id">UPI ID: <%= business_settings&.upi_id || '9972808044@ybl' %></p>
                      <div class="upi-icons">
                        <span class="phonepe">PhonePe</span>
                        <span class="gpay">Google Pay</span>
                      </div>
                    </td>
                    <td style="text-align: center;">
                      <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=upi://pay?pa=<%= business_settings&.upi_id || '9972808044@ybl' %>&pn=<%= CGI.escape(business_settings&.business_name || 'Marali Santhe') %>" alt="QR Code" class="qr-image" />
                    </td>
                  </tr>
                </table>
              </div>
            </td>
            <td class="payment-cell">
              <div class="tax-line">
                <span class="tax-label">TAXABLE AMOUNT</span>
                <span class="tax-amount">₹ <%= number_with_delimiter(taxable_amount.round(2), delimiter: ',') %></span>
              </div>
              <%
                # Group tax amounts by individual tax rates (same logic as HTML template)
                cgst_groups = {}
                sgst_groups = {}

                invoice_items.each do |item|
                  if item.product&.gst_enabled
                    base_amount = (item.quantity * (item.unit_price || 0)).round(2)

                    cgst_rate = item.product.cgst_percentage || 0
                    sgst_rate = item.product.sgst_percentage || 0

                    # If individual rates are not set, use main gst_percentage split evenly between CGST and SGST
                    if cgst_rate == 0 && sgst_rate == 0 && item.product.gst_percentage.present?
                      main_gst_rate = item.product.gst_percentage
                      cgst_rate = main_gst_rate / 2
                      sgst_rate = main_gst_rate / 2
                    end

                    if cgst_rate > 0
                      cgst_amount = (base_amount * cgst_rate / 100).round(2)
                      cgst_groups[cgst_rate] = (cgst_groups[cgst_rate] || 0) + cgst_amount
                    end

                    if sgst_rate > 0
                      sgst_amount = (base_amount * sgst_rate / 100).round(2)
                      sgst_groups[sgst_rate] = (sgst_groups[sgst_rate] || 0) + sgst_amount
                    end
                  end
                end
              %>
              <% cgst_groups.each do |rate, amount| %>
                <div class="tax-line">
                  <span class="tax-label">CGST @<%= rate %>%</span>
                  <span class="tax-amount">₹ <%= number_with_delimiter(amount.round(2), delimiter: ',') %></span>
                </div>
              <% end %>
              <% sgst_groups.each do |rate, amount| %>
                <div class="tax-line">
                  <span class="tax-label">SGST @<%= rate %>%</span>
                  <span class="tax-amount">₹ <%= number_with_delimiter(amount.round(2), delimiter: ',') %></span>
                </div>
              <% end %>
              <% if total_igst > 0 %>
                <% igst_rate = invoice_items.sum { |item| item.product&.gst_enabled ? (item.product.igst_percentage || 0) : 0 } / invoice_items.select { |item| item.product&.gst_enabled }.count rescue 0 %>
                  <div class="tax-line">
                    <span class="tax-label">IGST @<%= igst_rate %>%</span>
                    <span class="tax-amount">₹ <%= number_with_delimiter(total_igst.round(2), delimiter: ',') %></span>
                  </div>
              <% end %>
              <% if discount_amount > 0 %>
                <div class="tax-line">
                  <span class="tax-label">DISCOUNT</span>
                  <span class="tax-amount">-₹ <%= number_with_delimiter(discount_amount.round(2), delimiter: ',') %></span>
                </div>
              <% end %>
              <div class="total">
                <div class="tax-line">
                  <span class="tax-label">TOTAL AMOUNT</span>
                  <span class="tax-amount">₹ <%= number_with_delimiter(final_total.round(2), delimiter: ',') %></span>
                </div>
                <div class="tax-line" style="font-weight: normal; font-size: 10px;">
                  <span class="tax-label">Received Amount</span>
                  <span class="tax-amount">₹ <%= @invoice.payment_status == 'paid' ? number_with_delimiter(@invoice.total_amount, delimiter: ',') : '0' %></span>
                </div>
              </div>
              <div class="amount-words">
                <h3>Total Amount (in words)</h3>
                <%
                  # Convert number to words - enhanced implementation (same as HTML template)
                  total_amount_int = final_total.to_i
                  ones = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine"]
                  teens = ["Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen"]
                  tens = ["", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety"]

                  def convert_hundreds(n, ones, teens, tens)
                    result = ""
                    if n >= 100
                      result += ones[n / 100] + " Hundred "
                      n %= 100
                    end
                    if n >= 20
                      result += tens[n / 10] + " "
                      n %= 10
                    end
                    if n >= 10
                      result += teens[n - 10] + " "
                    elsif n > 0
                      result += ones[n] + " "
                    end
                    result
                  end

                  def number_to_words(number, ones, teens, tens)
                    return "Zero" if number == 0

                    result = ""
                    if number >= 10000000  # 1 crore
                      result += convert_hundreds(number / 10000000, ones, teens, tens) + "Crore "
                      number %= 10000000
                    end
                    if number >= 100000  # 1 lakh
                      result += convert_hundreds(number / 100000, ones, teens, tens) + "Lakh "
                      number %= 100000
                    end
                    if number >= 1000  # 1 thousand
                      result += convert_hundreds(number / 1000, ones, teens, tens) + "Thousand "
                      number %= 1000
                    end
                    if number > 0
                      result += convert_hundreds(number, ones, teens, tens)
                    end

                    result.strip
                  end

                  amount_in_words = number_to_words(total_amount_int, ones, teens, tens) + " Rupees Only"
                %>
                <p><%= amount_in_words %></p>
              </div>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table class="footer-table">
          <tr>
            <td class="terms-cell">
              <div class="terms">
                <h3>TERMS AND CONDITIONS</h3>
                <% if business_settings&.terms_and_conditions.present? %>
                  <% formatted_terms = business_settings.formatted_terms_and_conditions %>
                  <% if formatted_terms.respond_to?(:any?) && formatted_terms.any? %>
                    <ol>
                      <% formatted_terms.each do |term| %>
                        <li><%= term %></li>
                      <% end %>
                    </ol>
                  <% else %>
                    <p><%= business_settings.terms_and_conditions %></p>
                  <% end %>
                <% else %>
                  <ol>
                    <li>Payment is due within 30 days of invoice date</li>
                    <li>All products sold are subject to availability</li>
                    <li>Returns accepted within 7 days with receipt</li>
                  </ol>
                <% end %>
              </div>
            </td>
            <td class="signature-cell">
              <div class="signature-box"></div>
              <div class="signature-label">AUTHORISED SIGNATORY FOR</div>
              <div class="signature-name"><%= business_settings&.business_name || 'Marali Santhe' %></div>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </body>
</html>